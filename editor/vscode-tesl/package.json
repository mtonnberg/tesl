{
  "name": "vscode-tesl",
  "displayName": "Tesl Language",
  "description": "Syntax highlighting, live diagnostics, go-to-definition, hover types, and completions for the Tesl (.tesl) language",
  "version": "0.4.0",
  "publisher": "tesl",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/mtonnberg/tesl"
  },
  "bugs": {
    "url": "https://github.com/mtonnberg/tesl/issues"
  },
  "homepage": "https://github.com/mtonnberg/tesl",
  "icon": "images/icon.png",
  "keywords": [
    "tesl",
    "language",
    "lsp",
    "web api",
    "gdp",
    "type safety"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:tesl"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "tesl",
        "aliases": [
          "Tesl",
          "tesl"
        ],
        "extensions": [
          ".tesl"
        ],
        "configuration": "./language-configuration/tesl-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tesl",
        "scopeName": "source.tesl",
        "path": "./syntaxes/tesl.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Tesl",
      "properties": {
        "tesl.lspScript": {
          "type": "string",
          "default": "",
          "description": "Absolute path to tesl-lsp.rkt (advanced override). Leave empty to use the tesl-lsp binary from PATH (installed via nix profile install github:mtonnberg/tesl) or to auto-detect from the workspace."
        }
      }
    }
  },
  "scripts": {
    "package": "npx @vscode/vsce package",
    "publish:vsce": "npx @vscode/vsce publish",
    "publish:ovsx": "npx ovsx publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0"
  }
}
