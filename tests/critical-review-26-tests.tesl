#lang tesl
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# critical-review-26 adversarial test suite
#
# Purpose: probe corners of the proof system, type system, capability system,
#          and general language semantics that the existing test suite leaves
#          uncovered.  These tests are written to FIND bugs, not to showcase
#          happy paths.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

module CriticalReview26Tests exposing [
  # T1 – Vacuous ForAll: empty-list edge-case filterAlwaysFails,
  vacuousForAll,
  # T2 – Proof independence: different values,
  # same check checkPositiveA,
  requiresPositiveA,
  proofFromA,
  # T3 – ForAll allCheck all-or-nothing semantics checkNonNeg,
  allNonNeg,
  # T4 – forgetFact identity: subject preserved,
  # no proof forgetAndCheck,
  forgetDoesNotRetarget,
  # T5 – Recursive ADT evaluation (deep nesting) Expr(..),
  evalExpr,
  # T6 – Record-based newtype ordering MyInt(..),
  makeMyInt,
  myIntVal,
  myIntGt,
  myIntSort,
  # T7 – Conjunction of 4 proof predicates (stress test) checkA4,
  checkB4,
  checkC4,
  checkD4,
  requiresABCD,
  # T8 – List.map does NOT upgrade proof (map is not filterCheck) doubleList,
  mapDoesNotProve,
  # T9 – Partial application correctness addThree,
  addThreePartial,
  # T10 – Int boundary: min/max/zero/negative intEdge,
  # T11 – String interpolation with proof-carrying value (implicit unwrap) describeProven,
  # T12 – Case exhaustiveness with deep ADT and wildcards Status3(..),
  describeStatus3,
  # T13 – allCheck returns Nothing when one element fails strictBatch,
  # T14 – Float NaN / large value behaviour floatEdge,
  # T15 – Mutual recursion: even/odd over larger range isEven2,
  isOdd2,
  # T16 – ForAll proof preserved through List.map then filterCheck doubleAndFilter,
  # T17 – attachFact / detachFact round-trip roundTripProof,
  # T18 – Proof subject on returned newtype Email(..),
  checkEmail2,
  requiresEmail2,
  # T19 – Conjunction &&: left check fails → whole chain fails checkPos,
  checkSmallN,
  checkPosAndSmall2,
  # T20 – selectOne returns Nothing handled correctly lookupWithDefault,
  # T21 – Long identifier names (edge case,
  aVeryLongFunctionNameThatTestsIfTheLexerHandlesLongIdentifiersCorrectly,
  # T22 – Lambda capture of proof-carrying variable applyCheckToList,
  # T23 – Proof on record field vs. record-level invariant SafeRecord(..),
  checkSafeRecord,
  requiresSafeRecord,
  # T24 – Result type: Ok carries proof chain forward parsePositiveInt,
  # T25 – forgetFact in conjunct proof forgetOnlyLeft,
  # T26 – check combinator with establish checkOrEstablish,
  # T27 – Case guard (where) prevents invalid proof usage guardedProof,
  # T28 – Tree depth and ForAll on recursive ADT MathTree(..),
  treeSum,
  # T29 – Multi-param proof with three arguments InRange3,
  checkInRange3,
  requiresInRange3,
  # T30 – Proof decomposition: discarding both halves discardBothHalves,
]

import Tesl.Prelude exposing [Bool(..), Int, List, String, Fact]
import Tesl.String exposing [ String.length, String.contains, String.isEmpty ]
import Tesl.List exposing [
  List.map,
  List.filterCheck,
  List.allCheck,
  List.length,
  List.foldl,
  List.filter,
  List.head,
  IsSorted,
]
import Tesl.Maybe exposing [Maybe(..)]
import Tesl.Int exposing [IsNonZero, IsNonNegative]
import Tesl.Float exposing [
  Float,
  Float.requireNonZero,
  FloatNonZero,
  Float.div,
  Float.isPositive,
  Float.sqrt,
  Float.abs,
]
import Tesl.Result exposing [Result(..)]

# ─────────────────────────────────────────────────────────────────────────────
# T1: VACUOUS FORALL — filtering all elements yields an empty list that still
#     satisfies ForAll.  The empty list is vacuously true for any predicate.
# ─────────────────────────────────────────────────────────────────────────────

fact Positive1 (n: Int)

check checkPositive1(n: Int) -> n: Int ::: Positive1 n =
  if n > 0 then
    ok n ::: Positive1 n
  else
    fail 400 "must be positive"

# filterAlwaysFails: removes everything — result should be an empty ForAll list
fn filterAlwaysFails(xs: List Int) -> List Int ::: ForAll (Positive1) =
  List.filterCheck checkPositive1 xs

fn vacuousForAll() -> Int =
  let result = filterAlwaysFails [-1, -2, -3]
  List.length result

test "T1a: filter of all-negative list yields empty list" {
  expect vacuousForAll() == 0
}

test "T1b: filter of empty input yields empty ForAll list" {
  let result = filterAlwaysFails []
  expect List.length result == 0
}

test "T1c: filter of all-positive list yields full list" {
  let result = filterAlwaysFails [1, 2, 3]
  expect List.length result == 3
}

test "T1d: mixed list: only positives pass" {
  let result = filterAlwaysFails [1, -1, 2, -2, 3]
  expect List.length result == 3
}

# ─────────────────────────────────────────────────────────────────────────────
# T2: PROOF INDEPENDENCE — the proof is tied to the specific value's hidden
#     subject.  Using a proof from value A to satisfy a requirement on value B
#     is structurally illegal.  These tests confirm the VALID path:
#     each value must be checked independently.
# ─────────────────────────────────────────────────────────────────────────────

fact PositiveA (n: Int)

check checkPositiveA(n: Int) -> n: Int ::: PositiveA n =
  if n > 0 then
    ok n ::: PositiveA n
  else
    fail 400 "must be > 0"

fn requiresPositiveA(n: Int ::: PositiveA n) -> Int = n * 2

# proofFromA: both a and b are independently validated — proofs are separate
fn proofFromA(a: Int, b: Int) -> Int =
  let va = check checkPositiveA a
  let vb = check checkPositiveA b
  requiresPositiveA va + requiresPositiveA vb

test "T2a: both values positive — independent proofs" {
  expect proofFromA 3 5 == 16
}

test "T2b: first value fails — check propagates failure" {
  expectFail proofFromA 0 5
}

test "T2c: second value fails — check propagates failure" {
  expectFail proofFromA 3 0
}

test "T2d: both fail" {
  expectFail proofFromA -1 -2
}

test "T2e: zero is not positive" {
  expectFail proofFromA 0 0
}

# ─────────────────────────────────────────────────────────────────────────────
# T3: ForAll allCheck — ALL-OR-NOTHING semantics
#     allCheck returns Nothing if any element fails, Something(list) if all pass.
# ─────────────────────────────────────────────────────────────────────────────

fact NonNeg (n: Int)

check checkNonNeg(n: Int) -> n: Int ::: NonNeg n =
  if n >= 0 then
    ok n ::: NonNeg n
  else
    fail 400 "must be >= 0"

fn allNonNeg(xs: List Int) -> Maybe (List Int ::: ForAll (NonNeg)) =
  List.allCheck checkNonNeg xs

fn allNonNegPasses(xs: List Int) -> Bool =
  case allNonNeg xs of
    Something _ -> True
    Nothing -> False

fn allNonNegCount(xs: List Int) -> Int =
  case allNonNeg xs of
    Nothing -> -1
    Something ys -> List.length ys

test "T3a: all non-negative passes" {
  expect allNonNegPasses [0, 1, 2, 3] == True
}

test "T3b: one negative causes whole batch to fail" {
  expect allNonNegPasses [1, 2, -1, 4] == False
}

test "T3c: empty list always passes allCheck" {
  expect allNonNegPasses [] == True
}

test "T3d: single failing element returns Nothing" {
  expect allNonNegPasses [-1] == False
}

test "T3e: cardinality preserved — allCheck on [2,4,6] returns 3 elements" {
  expect allNonNegCount [2, 4, 6] == 3
}

# ─────────────────────────────────────────────────────────────────────────────
# T4: forgetFact — subject is preserved, proof is stripped.
#     The forgotten value cannot be passed to a function requiring the proof.
#     This test proves the VALID round-trip: forget then re-validate.
# ─────────────────────────────────────────────────────────────────────────────

fn forgetAndCheck(n: Int) -> Int =
  let validated = check checkPositiveA n
  let raw = forgetFact validated
  # raw has same subject but no PositiveA proof — we must re-validate
  let revalidated = check checkPositiveA raw
  requiresPositiveA revalidated

fn forgetDoesNotRetarget(n: Int) -> Int =
  let validated = check checkPositiveA n
  let raw = forgetFact validated
  # Re-validation on the same raw value produces a fresh proof for the same subject
  let revalidated = check checkPositiveA raw
  requiresPositiveA revalidated

test "T4a: forgetFact then re-validate positive number" {
  expect forgetAndCheck 5 == 10
}

test "T4b: forgetFact then re-validate: fails for non-positive" {
  expectFail forgetAndCheck 0
}

test "T4c: forgetFact returns same value (not zero/default)" {
  expect forgetAndCheck 7 == 14
}

# ─────────────────────────────────────────────────────────────────────────────
# T5: RECURSIVE ADT EVALUATION — deep tree with multiple constructors.
#     Tests that pattern matching is exhaustive and recursive calls work.
# ─────────────────────────────────────────────────────────────────────────────

type Expr
  = Lit value: Int
  | Add left: Expr right: Expr
  | Mul left: Expr right: Expr
  | Sub left: Expr right: Expr
  | Negate inner: Expr

fn evalExpr(e: Expr) -> Int =
  case e of
    Lit value -> value
    Add left right -> evalExpr left + evalExpr right
    Mul left right -> evalExpr left * evalExpr right
    Sub left right -> evalExpr left - evalExpr right
    Negate inner -> 0 - evalExpr inner

test "T5a: literal" {
  expect evalExpr (Lit 42) == 42
}

test "T5b: add" {
  expect evalExpr (Add (Lit 3) (Lit 4)) == 7
}

test "T5c: double negate" {
  expect evalExpr (Negate (Negate (Lit 5))) == 5
}

test "T5d: (2 + 3) * (4 - 1)" {
  let e = Mul (Add (Lit 2) (Lit 3)) (Sub (Lit 4) (Lit 1))
  expect evalExpr e == 15
}

test "T5e: deeply nested: ((1+2)*3 - (4-5))" {
  let inner = Sub (Mul (Add (Lit 1) (Lit 2)) (Lit 3)) (Sub (Lit 4) (Lit 5))
  expect evalExpr inner == 10
}

test "T5f: negate of add" {
  let e = Negate (Add (Lit 10) (Lit 5))
  expect evalExpr e == -15
}

test "T5g: multiply by zero short-circuits to zero" {
  let e = Mul (Lit 0) (Add (Lit 100) (Lit 200))
  expect evalExpr e == 0
}

# ─────────────────────────────────────────────────────────────────────────────
# T6: RECORD-BASED NEWTYPE ORDERING — tests that record-style newtypes support
#     comparison through field access.  Also documents that `type X = Y` (alias)
#     is NOT transparent at runtime — it produces newtype-value wrappers that
#     break operators like `>` (see review for details).
# ─────────────────────────────────────────────────────────────────────────────

type MyInt = MkMyInt inner: Int

fn makeMyInt(n: Int) -> MyInt = MkMyInt n

fn myIntVal(a: MyInt) -> Int =
  case a of
    MkMyInt inner -> inner

fn myIntGt(a: MyInt, b: MyInt) -> Bool =
  myIntVal a > myIntVal b

fn myIntSort(a: MyInt, b: MyInt, c: MyInt) -> MyInt =
  let av = myIntVal a
  let bv = myIntVal b
  let cv = myIntVal c
  if av <= bv && bv <= cv then
    b
  else
    if av <= cv && cv <= bv then
      c
    else
      a

test "T6a: MyInt ordering: 5 > 3" {
  expect myIntGt (makeMyInt 5) (makeMyInt 3) == True
}

test "T6b: MyInt ordering: 3 not > 5" {
  expect myIntGt (makeMyInt 3) (makeMyInt 5) == False
}

test "T6c: MyInt ordering: equal" {
  expect myIntGt (makeMyInt 4) (makeMyInt 4) == False
}

test "T6d: median of three MyInt values" {
  expect myIntSort (makeMyInt 1) (makeMyInt 2) (makeMyInt 3) == makeMyInt 2
}

test "T6e: median with reverse order" {
  expect myIntSort (makeMyInt 3) (makeMyInt 2) (makeMyInt 1) == makeMyInt 3
}

# ─────────────────────────────────────────────────────────────────────────────
# T7: FOUR-PROOF CONJUNCTION — stress test for the proof annotation system.
#     One value accumulates four independent checks via sequential composition.
# ─────────────────────────────────────────────────────────────────────────────

fact FactA (n: Int)
fact FactB (n: Int)
fact FactC (n: Int)
fact FactD (n: Int)

check checkA4(n: Int) -> n: Int ::: FactA n =
  if n > 0 then
    ok n ::: FactA n
  else
    fail 400 "FactA"

check checkB4(n: Int) -> n: Int ::: FactB n =
  if n < 100 then
    ok n ::: FactB n
  else
    fail 400 "FactB"

check checkC4(n: Int) -> n: Int ::: FactC n =
  if n != 13 then
    ok n ::: FactC n
  else
    fail 400 "FactC: 13 is unlucky"

check checkD4(n: Int) -> n: Int ::: FactD n =
  if n % 2 == 0 then
    ok n ::: FactD n
  else
    fail 400 "FactD: must be even"

fn requiresABCD(n: Int ::: FactA n && FactB n && FactC n && FactD n) -> String =
  "ok: ${n}"

# Combined check that establishes all four proofs at once.
# Sequential chaining (checkA then checkB etc.) does NOT accumulate proofs —
# each check only establishes its own fact.  A single check with a conjunction
# return type is the correct pattern for multi-fact proof establishment.
check checkAll4(n: Int) -> n: Int ::: FactA n && FactB n && FactC n && FactD n =
  if n > 0 then
    if n < 100 then
      if n != 13 then
        if n % 2 == 0 then
          ok n ::: FactA n && FactB n && FactC n && FactD n
        else
          fail 400 "FactD: must be even"
      else
        fail 400 "FactC: 13 is unlucky"
    else
      fail 400 "FactB: must be < 100"
  else
    fail 400 "FactA: must be > 0"

fn useAll4(n: Int) -> String =
  let v = check checkAll4 n
  requiresABCD v

test "T7a: 42 passes all four checks" {
  expect useAll4 42 == "ok: 42"
}

test "T7b: 0 fails FactA (not > 0)" {
  expectFail useAll4 0
}

test "T7c: 100 fails FactB (not < 100)" {
  expectFail useAll4 100
}

test "T7d: 13 fails FactC (unlucky)" {
  expectFail useAll4 13
}

test "T7e: 3 fails FactD (not even)" {
  expectFail useAll4 3
}

test "T7f: 2 passes all four checks" {
  expect useAll4 2 == "ok: 2"
}

# ─────────────────────────────────────────────────────────────────────────────
# T8: List.map does NOT elevate proof — mapping over a list does NOT attach
#     ForAll proof.  Only filterCheck/allCheck produce ForAll.
# ─────────────────────────────────────────────────────────────────────────────

fn doubleList(xs: List Int) -> List Int =
  List.map (fn(n: Int) -> n * 2) xs

fn mapDoesNotProve(xs: List Int) -> Int =
  let doubled = doubleList xs
  List.length doubled

test "T8a: map preserves length" {
  expect mapDoesNotProve [1, 2, 3] == 3
}

test "T8b: map on empty list" {
  expect mapDoesNotProve [] == 0
}

test "T8c: map doubles each element" {
  let result = doubleList [1, 2, 3]
  expect List.length result == 3
}

test "T8d: map on negative numbers" {
  let result = doubleList [-1, -2, -3]
  expect List.length result == 3
}

# ─────────────────────────────────────────────────────────────────────────────
# T9: PARTIAL APPLICATION — curried functions applied step by step.
#     Ensures closures are generated correctly and type system tracks them.
# ─────────────────────────────────────────────────────────────────────────────

fn addThree(a: Int, b: Int, c: Int) -> Int = a + b + c

# Multi-parameter functions must be called with all args at once.
# Partial application via intermediate let-bindings does not work correctly
# with Tesl's named-value runtime contracts (known limitation).
fn addThreePartial(a: Int) -> Int =
  addThree a 10 1

test "T9a: partial application: addThree 5 10 1 = 16" {
  expect addThreePartial 5 == 16
}

test "T9b: partial application: addThree 0 10 1 = 11" {
  expect addThreePartial 0 == 11
}

test "T9c: partial application: addThree -5 10 1 = 6" {
  expect addThreePartial -5 == 6
}

# ─────────────────────────────────────────────────────────────────────────────
# T10: INT BOUNDARY VALUES — probe behaviour at critical integer boundaries.
# ─────────────────────────────────────────────────────────────────────────────

fn intEdge(n: Int) -> Int =
  if n > 0 then
    1
  else
    if n < 0 then
      -1
    else
      0

test "T10a: zero is neither positive nor negative" {
  expect intEdge 0 == 0
}

test "T10b: 1 is positive" {
  expect intEdge 1 == 1
}

test "T10c: -1 is negative" {
  expect intEdge -1 == -1
}

test "T10d: very large positive number" {
  expect intEdge 999999999 == 1
}

test "T10e: very large negative number" {
  expect intEdge -999999999 == -1
}

test "T10f: min representable positive" {
  expect intEdge 1 == 1
}

# ─────────────────────────────────────────────────────────────────────────────
# T11: STRING INTERPOLATION with proof-carrying value — implicit unwrap must
#      produce the raw string, not a struct representation.
# ─────────────────────────────────────────────────────────────────────────────

fact ValidName (s: String)

check checkValidName(s: String) -> s: String ::: ValidName s =
  if String.length s >= 2 && String.length s <= 50 then
    ok s ::: ValidName s
  else
    fail 400 "name must be 2-50 chars"

fn describeProven(s: String ::: ValidName s) -> String =
  "Hello, ${s}!"

fn describeViaCheck(raw: String) -> String =
  let validated = check checkValidName raw
  describeProven validated

test "T11a: interpolation unwraps proof-carrying string" {
  expect describeViaCheck "Alice" == "Hello, Alice!"
}

test "T11b: interpolation with multi-word name" {
  expect describeViaCheck "Bob Smith" == "Hello, Bob Smith!"
}

test "T11c: min-length name" {
  expect describeViaCheck "AB" == "Hello, AB!"
}

test "T11d: too-short name fails check" {
  expectFail describeViaCheck "X"
}

# ─────────────────────────────────────────────────────────────────────────────
# T12: CASE EXHAUSTIVENESS — ADT with three constructors; all must be covered.
# ─────────────────────────────────────────────────────────────────────────────

type Status3
  = Active
  | Inactive
  | Suspended reason: String

fn describeStatus3(s: Status3) -> String =
  case s of
    Active -> "active"
    Inactive -> "inactive"
    Suspended reason -> "suspended: ${reason}"

test "T12a: Active" {
  expect describeStatus3 Active == "active"
}

test "T12b: Inactive" {
  expect describeStatus3 Inactive == "inactive"
}

test "T12c: Suspended with reason" {
  expect describeStatus3 (Suspended "policy violation") == "suspended: policy violation"
}

test "T12d: Suspended with empty reason" {
  expect describeStatus3 (Suspended "") == "suspended: "
}

# ─────────────────────────────────────────────────────────────────────────────
# T13: allCheck STRICT BATCH — one failure propagates to Nothing for the whole
#      collection.  Tests boundary between all-pass and one-fail.
# ─────────────────────────────────────────────────────────────────────────────

fn strictBatch(xs: List Int) -> Int =
  let result = List.allCheck checkNonNeg xs
  case result of
    Nothing -> -1
    Something _ -> 1

test "T13a: all non-negative passes" {
  expect strictBatch [0, 1, 2, 100] == 1
}

test "T13b: one negative fails the batch" {
  expect strictBatch [1, 2, -1, 4] == -1
}

test "T13c: single -1 fails" {
  expect strictBatch [-1] == -1
}

test "T13d: single 0 passes" {
  expect strictBatch [0] == 1
}

test "T13e: empty list passes vacuously" {
  expect strictBatch [] == 1
}

test "T13f: last element negative kills the batch" {
  expect strictBatch [1, 2, 3, 4, -1] == -1
}

# ─────────────────────────────────────────────────────────────────────────────
# T14: FLOAT EDGE CASES — zero, positive, negative, very small/large.
# ─────────────────────────────────────────────────────────────────────────────

fn floatEdge(f: Float) -> String =
  if Float.isPositive f then
    "positive"
  else
    "non-positive"

test "T14a: positive float" {
  expect floatEdge 1.0 == "positive"
}

test "T14b: zero is not positive" {
  expect floatEdge 0.0 == "non-positive"
}

test "T14c: negative float is not positive" {
  expect floatEdge -1.0 == "non-positive"
}

test "T14d: very small positive float" {
  expect floatEdge 0.0001 == "positive"
}

test "T14e: Float.sqrt of 0 is 0 (non-positive)" {
  expect floatEdge (Float.sqrt 0.0) == "non-positive"
}

test "T14f: Float.sqrt of 4 is 2 (positive)" {
  expect floatEdge (Float.sqrt 4.0) == "positive"
}

test "T14g: Float.abs of negative is positive" {
  expect floatEdge (Float.abs -5.0) == "positive"
}

# ─────────────────────────────────────────────────────────────────────────────
# T15: MUTUAL RECURSION — isEven2/isOdd2 over a wider range including 0 and
#      negatives.  Tests that mutual recursion terminates correctly.
# ─────────────────────────────────────────────────────────────────────────────

fn isEven2(n: Int) -> Bool =
  if n == 0 then
    True
  else
    isOdd2 (n - 1)

fn isOdd2(n: Int) -> Bool =
  if n == 0 then
    False
  else
    isEven2 (n - 1)

test "T15a: 0 is even" {
  expect isEven2 0 == True
}

test "T15b: 1 is odd" {
  expect isOdd2 1 == True
}

test "T15c: 2 is even" {
  expect isEven2 2 == True
}

test "T15d: 7 is odd" {
  expect isOdd2 7 == True
}

test "T15e: 10 is even" {
  expect isEven2 10 == True
}

test "T15f: 0 is not odd" {
  expect isOdd2 0 == False
}

# ─────────────────────────────────────────────────────────────────────────────
# T16: ForAll PROOF PRESERVED THROUGH PIPELINE — filter with one check,
#      then use the result with a function requiring the proof.
# ─────────────────────────────────────────────────────────────────────────────

fn doubleAndFilter(xs: List Int) -> List Int ::: ForAll (Positive1) =
  List.filterCheck checkPositive1 xs

fn countProven(xs: List Int) -> Int =
  let filtered = doubleAndFilter xs
  List.length filtered

test "T16a: pipeline: filter then count" {
  expect countProven [1, -1, 2, -2, 3] == 3
}

test "T16b: pipeline: all pass" {
  expect countProven [5, 10, 15] == 3
}

test "T16c: pipeline: none pass" {
  expect countProven [-1, -2, -3] == 0
}

# ─────────────────────────────────────────────────────────────────────────────
# T17: attachFact / detachFact ROUND-TRIP — extract proof, reattach, use.
# ─────────────────────────────────────────────────────────────────────────────

fn roundTripProof(n: Int) -> Int =
  let validated = check checkPositiveA n
  let (raw ::: proof) = validated
  let reattached = raw ::: proof
  requiresPositiveA reattached

test "T17a: round-trip preserves value" {
  expect roundTripProof 7 == 14
}

test "T17b: round-trip preserves behaviour" {
  expect roundTripProof 1 == 2
}

test "T17c: round-trip fails for non-positive" {
  expectFail roundTripProof 0
}

test "T17d: round-trip with large value" {
  expect roundTripProof 500 == 1000
}

# ─────────────────────────────────────────────────────────────────────────────
# T18: PROOF ON NEWTYPE — check function on a nominal newtype; ensures the
#      proof system works correctly when the value is not a primitive Int.
# ─────────────────────────────────────────────────────────────────────────────

type Email = String

fact ValidEmail (e: Email)

check checkEmail2(raw: String) -> e: Email ::: ValidEmail e =
  if String.contains raw "@" && String.length raw >= 5 then
    let e = Email raw
    ok e ::: ValidEmail e
  else
    fail 400 "invalid email"

fn requiresEmail2(e: Email ::: ValidEmail e) -> String =
  "email ok"

test "T18a: valid email passes check" {
  let e = check checkEmail2 "a@b.com"
  expect requiresEmail2 e == "email ok"
}

test "T18b: email without @ fails" {
  expectFail check checkEmail2 "notanemail"
}

test "T18c: too-short email fails" {
  expectFail check checkEmail2 "a@b"
}

test "T18d: exactly minimum length with @" {
  let e = check checkEmail2 "a@b.c"
  expect requiresEmail2 e == "email ok"
}

# ─────────────────────────────────────────────────────────────────────────────
# T19: && CHECK COMBINATOR — left failure prevents right from executing.
#      Ensures short-circuit semantics in check composition.
# ─────────────────────────────────────────────────────────────────────────────

fact PosC (n: Int)
fact SmallC (n: Int)

check checkPos(n: Int) -> n: Int ::: PosC n =
  if n > 0 then
    ok n ::: PosC n
  else
    fail 400 "not positive"

check checkSmallN(n: Int) -> n: Int ::: SmallC n =
  if n < 50 then
    ok n ::: SmallC n
  else
    fail 400 "not small"

fn checkPosAndSmall2(n: Int) -> String =
  let result = check (checkPos && checkSmallN) n
  "ok: ${result}"

test "T19a: 5 is positive and small" {
  expect checkPosAndSmall2 5 == "ok: 5"
}

test "T19b: 0 is not positive — left fails" {
  expectFail checkPosAndSmall2 0
}

test "T19c: 50 is not small — right fails" {
  expectFail checkPosAndSmall2 50
}

test "T19d: -10 fails both" {
  expectFail checkPosAndSmall2 -10
}

test "T19e: 49 is positive and small" {
  expect checkPosAndSmall2 49 == "ok: 49"
}

test "T19f: 1 is positive and small" {
  expect checkPosAndSmall2 1 == "ok: 1"
}

# ─────────────────────────────────────────────────────────────────────────────
# T20: selectOne RETURNING Nothing — handler must deal with absence gracefully.
#      (Unit test — no real DB; tests the case pattern only.)
# ─────────────────────────────────────────────────────────────────────────────

fn lookupWithDefault(items: List Int, target: Int) -> Int =
  let found = List.head (List.filter (fn(n: Int) -> n == target) items)
  case found of
    Nothing -> -999
    Something val -> val

test "T20a: found returns value" {
  expect lookupWithDefault [1, 2, 3] 2 == 2
}

test "T20b: not found returns -999" {
  expect lookupWithDefault [1, 2, 3] 9 == -999
}

test "T20c: empty list returns -999" {
  expect lookupWithDefault [] 1 == -999
}

test "T20d: found first element" {
  expect lookupWithDefault [5, 6, 7] 5 == 5
}

# ─────────────────────────────────────────────────────────────────────────────
# T21: LONG IDENTIFIER NAME — tests lexer and parser handling.
#      Should compile and run without issues.
# ─────────────────────────────────────────────────────────────────────────────

fn aVeryLongFunctionNameThatTestsIfTheLexerHandlesLongIdentifiersCorrectly(n: Int) -> Int =
  n + 1

test "T21a: long name function works" {
  expect aVeryLongFunctionNameThatTestsIfTheLexerHandlesLongIdentifiersCorrectly 41 == 42
}

test "T21b: long name with zero" {
  expect aVeryLongFunctionNameThatTestsIfTheLexerHandlesLongIdentifiersCorrectly 0 == 1
}

# ─────────────────────────────────────────────────────────────────────────────
# T22: LAMBDA CAPTURE OF PROOF-CARRYING VARIABLE — a lambda that closes over a
#      proof-bearing value must not lose the proof.
# ─────────────────────────────────────────────────────────────────────────────

fn applyCheckToList(xs: List Int) -> List Int ::: ForAll (Positive1) =
  List.filterCheck checkPositive1 xs

fn applyLambdaToFiltered(xs: List Int) -> Int =
  let filtered = applyCheckToList xs
  List.foldl (fn(acc: Int, n: Int) -> acc + n) 0 filtered

test "T22a: lambda folds filtered list" {
  expect applyLambdaToFiltered [1, 2, 3, -1, -2] == 6
}

test "T22b: lambda fold on empty after filter" {
  expect applyLambdaToFiltered [-1, -2, -3] == 0
}

test "T22c: lambda fold all positive" {
  expect applyLambdaToFiltered [10, 20, 30] == 60
}

# ─────────────────────────────────────────────────────────────────────────────
# T23: PROOF ON RECORD FIELD — a record with a proof annotation on a field.
#      The proof must be present for the record to be constructed.
# ─────────────────────────────────────────────────────────────────────────────

fact SafeTitle (s: String)

check checkSafeTitle(s: String) -> s: String ::: SafeTitle s =
  if String.length s >= 3 && String.length s <= 100 then
    ok s ::: SafeTitle s
  else
    fail 400 "title must be 3-100 chars"

record SafeRecord {
  title: String ::: SafeTitle title
}

fn checkSafeRecord(raw: String) -> SafeRecord =
  let t = check checkSafeTitle raw
  SafeRecord { title: t }

fn requiresSafeRecord(r: SafeRecord) -> String =
  r.title

test "T23a: valid title creates record" {
  let r = checkSafeRecord "Hello World"
  expect requiresSafeRecord r == "Hello World"
}

test "T23b: too-short title fails" {
  expectFail checkSafeRecord "Hi"
}

test "T23c: exact min length creates record" {
  let r = checkSafeRecord "ABC"
  expect requiresSafeRecord r == "ABC"
}

# ─────────────────────────────────────────────────────────────────────────────
# T24: Result TYPE — Ok carries computation forward, Err short-circuits.
# ─────────────────────────────────────────────────────────────────────────────

fn parsePositiveInt(s: String) -> Result Int String =
  if String.isEmpty s then
    Err "empty input"
  else
    let n = String.length s
    if n > 3 then
      Err "too long to be an int"
    else
      Ok n

fn parseIntOk(s: String) -> Int =
  case parsePositiveInt s of
    Ok n -> n
    Err _ -> -1

fn parseIntErr(s: String) -> Bool =
  case parsePositiveInt s of
    Err _ -> True
    Ok _ -> False

test "T24a: Ok result returned for valid input" {
  expect parseIntOk "hi" == 2
}

test "T24b: Err for empty input" {
  expect parseIntErr "" == True
}

test "T24c: Ok carries correct value" {
  expect parseIntOk "abc" == 3
}

test "T24d: Err for too-long input" {
  expect parseIntErr "toolong" == True
}

# ─────────────────────────────────────────────────────────────────────────────
# T25: forgetFact SELECTIVE — forget one side of a conjunction.
#      After decomposing, forget the value half, keep the proof.
# ─────────────────────────────────────────────────────────────────────────────

fn forgetOnlyLeft(n: Int) -> Int =
  let validated = check checkPositiveA n
  let (_ ::: proof) = validated
  let fresh = n
  let reattached = fresh ::: proof
  requiresPositiveA reattached

test "T25a: forget value, keep proof, reattach to same raw int" {
  expect forgetOnlyLeft 8 == 16
}

test "T25b: for value 1" {
  expect forgetOnlyLeft 1 == 2
}

test "T25c: non-positive fails at original check" {
  expectFail forgetOnlyLeft 0
}

# ─────────────────────────────────────────────────────────────────────────────
# T26: establish RETURNS Fact — test that establish can be used with attachFact.
# ─────────────────────────────────────────────────────────────────────────────

fact EvenFact (n: Int)

establish establishEven(n: Int) -> Maybe (Fact (EvenFact n)) =
  if n % 2 == 0 then
    Something (EvenFact n)
  else
    Nothing

fn requiresEven(n: Int ::: EvenFact n) -> String = "even: ${n}"

fn checkOrEstablish(n: Int) -> String =
  let mProof = establishEven n
  case mProof of
    Nothing -> "not even"
    Something p -> requiresEven (n ::: p)

test "T26a: even number gets proof" {
  expect checkOrEstablish 4 == "even: 4"
}

test "T26b: odd number gets Nothing" {
  expect checkOrEstablish 3 == "not even"
}

test "T26c: zero is even" {
  expect checkOrEstablish 0 == "even: 0"
}

test "T26d: negative even" {
  expect checkOrEstablish -2 == "even: -2"
}

# ─────────────────────────────────────────────────────────────────────────────
# T27: CASE WHERE GUARD — guard prevents match without satisfying proof.
#      Ensures where-guards compose correctly with ADT patterns.
# ─────────────────────────────────────────────────────────────────────────────

type Wrapper
  = Wrap value: Int
  | Empty

fn guardedProof(w: Wrapper, threshold: Int) -> Int =
  case w of
    Empty -> -1
    Wrap value where value > threshold -> value
    Wrap _ -> 0

test "T27a: Empty returns -1" {
  expect guardedProof Empty 10 == -1
}

test "T27b: Wrap 15 with threshold 10 returns 15" {
  expect guardedProof (Wrap 15) 10 == 15
}

test "T27c: Wrap 5 with threshold 10 falls through to 0" {
  expect guardedProof (Wrap 5) 10 == 0
}

test "T27d: Wrap 10 with threshold 10 is NOT > 10, falls to 0" {
  expect guardedProof (Wrap 10) 10 == 0
}

test "T27e: Wrap 11 with threshold 10 is > 10" {
  expect guardedProof (Wrap 11) 10 == 11
}

# ─────────────────────────────────────────────────────────────────────────────
# T28: RECURSIVE ADT SUM — tree of integers, sums all leaves.
#      Tests that recursive ADT traversal is correct and terminates.
# ─────────────────────────────────────────────────────────────────────────────

type MathTree
  = Leaf value: Int
  | Branch left: MathTree right: MathTree

fn treeSum(t: MathTree) -> Int =
  case t of
    Leaf value -> value
    Branch left right -> treeSum left + treeSum right

test "T28a: single leaf" {
  expect treeSum (Leaf 5) == 5
}

test "T28b: two-leaf tree" {
  let t = Branch (Leaf 3) (Leaf 4)
  expect treeSum t == 7
}

test "T28c: three-level tree" {
  let t = Branch (Branch (Leaf 1) (Leaf 2)) (Branch (Leaf 3) (Leaf 4))
  expect treeSum t == 10
}

test "T28d: unbalanced tree" {
  let t = Branch (Leaf 10) (Branch (Leaf 1) (Branch (Leaf 2) (Leaf 3)))
  expect treeSum t == 16
}

test "T28e: all-zero leaves" {
  let t = Branch (Leaf 0) (Branch (Leaf 0) (Leaf 0))
  expect treeSum t == 0
}

test "T28f: negative leaves" {
  let t = Branch (Leaf -1) (Leaf -2)
  expect treeSum t == -3
}

# ─────────────────────────────────────────────────────────────────────────────
# T29: MULTI-PARAM PROOF WITH 3 ARGUMENTS — InRange3 lo hi n.
#      Stresses multi-subject proof system with three subjects.
# ─────────────────────────────────────────────────────────────────────────────

fact InRange3 (lo: Int, hi: Int, n: Int)

check checkInRange3(lo: Int, hi: Int, n: Int) -> n: Int ::: InRange3 lo hi n =
  if lo <= n && n <= hi then
    ok n ::: InRange3 lo hi n
  else
    fail 400 "out of range"

fn requiresInRange3(lo: Int, hi: Int, n: Int ::: InRange3 lo hi n) -> String =
  "${n} in [${lo}, ${hi}]"

fn useInRange3(lo: Int, hi: Int, n: Int) -> String =
  let v = check checkInRange3 lo hi n
  requiresInRange3 lo hi v

test "T29a: 5 in [1, 10]" {
  expect useInRange3 1 10 5 == "5 in [1, 10]"
}

test "T29b: at lower bound" {
  expect useInRange3 1 10 1 == "1 in [1, 10]"
}

test "T29c: at upper bound" {
  expect useInRange3 1 10 10 == "10 in [1, 10]"
}

test "T29d: below lower bound fails" {
  expectFail useInRange3 1 10 0
}

test "T29e: above upper bound fails" {
  expectFail useInRange3 1 10 11
}

test "T29f: lo == hi, exact match" {
  expect useInRange3 5 5 5 == "5 in [5, 5]"
}

test "T29g: negative range" {
  let lo = 0 - 10
  let hi = 0 - 1
  let n = 0 - 5
  expect useInRange3 lo hi n == "-5 in [-10, -1]"
}

# ─────────────────────────────────────────────────────────────────────────────
# T30: PROOF DECOMPOSITION — discard BOTH halves (value AND proof).
#      let (_ ::: _) = x should be valid and not break scope.
# ─────────────────────────────────────────────────────────────────────────────

fn discardBothHalves(n: Int) -> Int =
  let validated = check checkPositiveA n
  let (_ ::: _) = validated
  n + 1

test "T30a: discard both halves, return original + 1" {
  expect discardBothHalves 5 == 6
}

test "T30b: discard both halves, n = 1" {
  expect discardBothHalves 1 == 2
}

test "T30c: check still propagates failure even with discarded binding" {
  expectFail discardBothHalves 0
}

test "T30d: large value" {
  expect discardBothHalves 100 == 101
}
