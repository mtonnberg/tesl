#lang tesl
module Email_tests exposing []

import Tesl.Prelude exposing [String, Unit, Bool(..)]

database TestDB {
  schema: public
  backend: postgres {}
}

# ── Email declarations ─────────────────────────────────────────────────────

email AppEmail {
  database: TestDB
  smtp {
    host: env("SMTP_HOST")
    port: 587
    username: env("SMTP_USER")
    password: env("SMTP_PASS")
    tls: true
  }
}

email MarketingEmail {
  database: TestDB
  smtp {
    host: env("MKT_SMTP_HOST")
    port: 465
    username: env("MKT_SMTP_USER")
    password: env("MKT_SMTP_PASS")
    tls: true
  }
}

email NoTlsEmail {
  database: TestDB
  smtp {
    host: env("SMTP_HOST")
    port: 25
    username: env("SMTP_USER")
    password: env("SMTP_PASS")
    tls: false
  }
}

# ── Helper functions ───────────────────────────────────────────────────────

fn sendWelcome(addr: String) -> Unit requires [email] =
  Email.send AppEmail {
    to: addr
    subject: "Welcome!"
    body: RichBody "Hello!" "<h1>Hello!</h1>"
  }

fn sendSimple(addr: String, subj: String) -> Unit requires [email] =
  Email.send AppEmail {
    to: addr
    subject: subj
    body: TextBody "Hello from Tesl"
  }

fn sendTextOnly(addr: String, bodyText: String) -> Unit requires [email] =
  Email.send AppEmail {
    to: addr
    subject: "Notification"
    body: TextBody bodyText
  }

fn sendHtmlOnly(addr: String, html: String) -> Unit requires [email] =
  Email.send AppEmail {
    to: addr
    subject: "HTML Email"
    body: HtmlBody html
  }

fn sendMarketing(addr: String) -> Unit requires [email] =
  Email.send MarketingEmail {
    to: addr
    subject: "Special Offer"
    body: RichBody "Check out our deals" "<p>Check out our deals</p>"
  }

fn sendMultiple(a: String, b: String) -> Unit requires [email] =
  let _ = Email.send AppEmail { to: a subject: "First" body: TextBody "Hello" }
  Email.send AppEmail { to: b subject: "Second" body: TextBody "Bye" }

fn startEmailServices() -> Unit requires [email] =
  startEmailWorker AppEmail

fn startAllEmailServices() -> Unit requires [email] =
  let _ = Email.send AppEmail { to: "admin@example.com" subject: "Starting" body: TextBody "Services starting" }
  startEmailWorker AppEmail

