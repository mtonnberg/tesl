#lang tesl
# ─────────────────────────────────────────────────────────────────────────────
# critical-review-35-tests.tesl
#
# Adversarial test suite for critical review 35.
# Focus areas:
#   1.  Proof system soundness — cross-subject confusion, re-targeting
#   2.  Capability enforcement — transitive chains, missing declarations
#   3.  ADT exhaustiveness — parameterized ADTs, nested patterns
#   4.  Integer overflow behavior near fixnum boundary
#   5.  Newtype safety — nominal distinctness under composition
#   6.  ForAll proof chain integrity after multiple filterCheck passes
#   7.  Establish as unsafe boundary — unconditional proof for wrong values
#   8.  Proof decomposition and recombination edge cases
#   9.  Case guard interaction with pattern binding
#   10. Partial application with proof-bearing arguments
#   11. Higher-order functions with proof-requiring callbacks
#   12. String operations at boundaries (empty, unicode-like, escapes)
#   13. Dict/Set proof roundtrips
#   14. Maybe nesting — Maybe (Maybe a)
#   15. Record field proof propagation across function boundaries
#   16. List.foldl correctness for various accumulator patterns
#   17. Lambda type inference in higher-order contexts
#   18. Boolean expression short-circuit and equality
#   19. Recursive ADT deep traversal
#   20. Float edge cases — division, comparison
#   21. Check composition failure ordering
#   22. Proof conjunction and decomposition with &&
#   23. Property-based tests for stdlib laws
#   24. Multiple check calls in sequence — proof accumulation
#   25. Newtype round-trip through function boundary
# ─────────────────────────────────────────────────────────────────────────────
module CriticalReview35Tests exposing [
  # T01 — Cross-subject proof cannot be reused checkNonNeg35,
  requireNonNeg35,
  # T02 — Check composition failure ordering checkA35,
  checkB35,
  # T03 — ForAll survives through double filterCheck checkEv35,
  checkSmall35,
  # T04 — Establish is unconditional (unsafe boundary) alwaysTrue35,
  requiresTrue35,
  # T05 — Proof decomposition via let (x ::: p) = y checkPosDecomp35,
  # T06 — Recursive ADT: list implemented as ADT MyList35(..),
  myLength35,
  myMap35,
  myAppend35,
  # T07 — Maybe nesting flattenMaybe35,
  # T08 — Record field proof propagation SafeTitle35,
  checkSafeTitle35,
  ProvenRecord35,
  readAndConsume35,
  # T09 — Integer arithmetic laws near boundaries # T10 — Float division proof safeFloatDiv35,
  # T11 — Boolean expression completeness xor35,
  nand35,
  # T12 — Newtype round-trip UserId35(..),
  wrapAndUnwrap35,
  # T13 — Case guard with complex predicate Prio35(..),
  classifyPrio35,
  # T14 — List.foldl correctness sumFold35,
  productFold35,
  concatFold35,
  # T15 — Lambda captures and HOF applyN35,
  # T16 — Partial application of 3-arg fn add335,
  # T17 — Multiple sequential checks accumulate proofs checkPos35,
  checkSmallInt35,
  requiresBoth35,
  sequentialChecks35,
  # T18 — String escape and edge cases # T19 — Dict roundtrip # T20 — Set deduplication and ordering # T21 — Parameterized ADT with nested type params Pair35(..),
  swapPair35,
  mapPair35,
  # T22 — Check that forgetFact truly removes proof # T23 — Empty and singleton edge cases # T24 — Property: addition is commutative and associative # T25 — Property: List.reverse . List.reverse = id,
]

