import Tesl.String exposing [
  String.length,
  String.isEmpty,
  String.trim,
  String.contains,
  String.replace,
  String.split,
  String.join,
  String.startsWith,
  String.endsWith,
  String.toUpper,
  String.toLower,
  String.indexOf,
  IsTrimmed,
  IsUpperCase,
]
