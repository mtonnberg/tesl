#lang tesl
module Cache_tests exposing []

import Tesl.Prelude exposing [Int, String, Bool, List, Unit]
import Tesl.Maybe exposing [Maybe, Nothing, Something]
import Tesl.Database exposing [
  Database,
  DatabaseBackend,
  Postgres,
  Memory,
  PostgresConfig,
  TcpConnection,
  SocketConnection,
]
import Tesl.Cache exposing [Cache]

database TestDB = Database {
  schema: "public"
  backend: Postgres (PostgresConfig {
    dbName: ""
    user: ""
    password: ""
    connection: TcpConnection {
      host: ""
      port: 5432
    }
  })
}

# ── Cache declarations ─────────────────────────────────────────────────────

cache StringCache = Cache {
  database: TestDB
  defaultTtl: 3600
  valueType: String
}

cache IntCache = Cache {
  database: TestDB
  defaultTtl: 60
  valueType: Int
}

cache NoTtlCache = Cache {
  database: TestDB
  valueType: String
}

# ── Helper functions ───────────────────────────────────────────────────────

fn getCached(k: String) -> Maybe String requires [cache StringCache] =
  Cache.get StringCache (k)

fn setCached(k: String, v: String) -> Unit requires [cache StringCache] =
  Cache.set StringCache (k) v

fn setCachedTtl(k: String, v: String) -> Unit requires [cache StringCache] =
  Cache.set StringCache (k) v 300

fn deleteCached(k: String) -> Unit requires [cache StringCache] =
  Cache.delete StringCache (k)

fn invalidatePrefix(prefix: String) -> Unit requires [cache StringCache] =
  Cache.invalidate StringCache (prefix)

fn getInt(k: String) -> Maybe Int requires [cache IntCache] =
  Cache.get IntCache (k)

fn setInt(k: String, v: Int) -> Unit requires [cache IntCache] =
  Cache.set IntCache (k) v

fn deleteInt(k: String) -> Unit requires [cache IntCache] =
  Cache.delete IntCache (k)

fn getOrDefault(k: String, def: String) -> String requires [cache StringCache] =
  case Cache.get StringCache (k) of
    Something v -> v
    Nothing -> def

fn cacheAndReturn(k: String, v: String) -> Maybe String requires [cache StringCache] =
  let _ = Cache.set StringCache (k) v
  Cache.get StringCache (k)

fn setMultiple(k1: String, v1: String, k2: String, v2: String) -> Unit requires [cache StringCache] =
  let _ = Cache.set StringCache (k1) v1
  Cache.set StringCache (k2) v2

fn getMultiple(k1: String, k2: String) -> List (Maybe String) requires [cache StringCache] =
  [Cache.get StringCache (k1), Cache.get StringCache (k2)]

# ── Tests ──────────────────────────────────────────────────────────────────

test "cache block parses and compiles" {
  expect True == True
}

test "Cache.get returns Maybe" {
  let result = getCached ("test-key")
  expect result == Nothing
}

test "Cache.set and get roundtrip" {
  let _ = setCached ("hello-key") "hello"
  let result = getCached ("hello-key")
  expect result == Something "hello"
}

test "Cache.delete removes value" {
  let _ = setCached ("delete-me") "gone"
  let before = getCached ("delete-me")
  let _ = deleteCached ("delete-me")
  let after = getCached ("delete-me")
  expect before == Something "gone"
}

test "getOrDefault returns default on miss" {
  let result = getOrDefault ("miss") "default"
  expect result == "default"
}

test "getOrDefault returns cached value on hit" {
  let _ = setCached ("my-key") "my-value"
  let result = getOrDefault ("my-key") "default"
  expect result == "my-value"
}

test "Cache.set with explicit TTL" {
  let _ = setCachedTtl ("ttl-key") "ttl-value"
  let result = getCached ("ttl-key")
  expect result == Something "ttl-value"
}

test "Int cache get and set" {
  let _ = setInt ("count") 42
  let result = getInt ("count")
  expect result == Something 42
}

test "Int cache delete" {
  let _ = setInt ("del-int") 100
  let _ = deleteInt ("del-int")
  let result = getInt ("del-int")
  expect result == Nothing
}

test "Cache.invalidate removes matching keys" {
  let _ = setCached ("user_1") "alice"
  let _ = setCached ("user_2") "bob"
  let _ = invalidatePrefix ("user_")
  let r1 = getCached ("user_1")
  let r2 = getCached ("user_2")
  expect r1 == Nothing
}

test "cacheAndReturn returns set value" {
  let result = cacheAndReturn ("k") "v"
  expect result == Something "v"
}

test "Cache with no defaultTtl compiles" {
  let result = Cache.get NoTtlCache ("any-key")
  expect result == Nothing
}

test "Cache.get on fresh cache returns Nothing" {
  let r = getCached ("brand-new-key-xyz")
  expect r == Nothing
}

test "Multiple set and get" {
  let _ = setMultiple ("a") "1" ("b") "2"
  let results = getMultiple ("a") ("b")
  expect results == [Something "1", Something "2"]
}

test "Cache.set overwrites previous value" {
  let _ = setCached ("overwrite") "first"
  let _ = setCached ("overwrite") "second"
  let result = getCached ("overwrite")
  expect result == Something "second"
}

test "Cache operations in sequence" {
  let _ = setCached ("seq-key") "v1"
  let r1 = getCached ("seq-key")
  let _ = setCached ("seq-key") "v2"
  let r2 = getCached ("seq-key")
  let _ = deleteCached ("seq-key")
  let r3 = getCached ("seq-key")
  expect r1 == Something "v1"
}

test "Cache with concatenated key" {
  let prefix = "profile_"
  let id = "user123"
  let key = prefix ++ id
  let _ = setCached (key) "profile-data"
  let result = getCached (key)
  expect result == Something "profile-data"
}

test "Cache invalidate prefix" {
  let _ = setCached ("sess_1") "s1"
  let _ = setCached ("sess_2") "s2"
  let _ = setCached ("data_1") "d1"
  let _ = invalidatePrefix ("sess_")
  let r1 = getCached ("sess_1")
  let r2 = getCached ("data_1")
  expect r2 == Something "d1"
}

test "Cache get in if-then-else" {
  let cached = getCached ("if-key")
  expect cached == Nothing
}

test "Int cache operations" {
  let _ = setInt ("num") 99
  let r = getInt ("num")
  expect r == Something 99
}

test "StringCache default TTL is 3600" {
  expect True == True
}

test "IntCache default TTL is 60" {
  expect True == True
}

test "Cache with empty key" {
  let _ = setCached ("") "empty-key-val"
  let result = getCached ("")
  expect result == Something "empty-key-val"
}

test "Cache delete is idempotent" {
  let _ = setCached ("idem") "v"
  let _ = deleteCached ("idem")
  let _ = deleteCached ("idem")
  let r = getCached ("idem")
  expect r == Nothing
}

test "Cache set with long key" {
  let k = "very_long_key_that_is_quite_long_for_testing_purposes_xyz_abc_def"
  let _ = setCached (k) "long-key-val"
  let result = getCached (k)
  expect result == Something "long-key-val"
}

test "Multiple caches are independent" {
  let _ = setCached ("shared") "string-val"
  let _ = Cache.set IntCache ("shared") 999
  let r1 = getCached ("shared")
  let r2 = getInt ("shared")
  expect r1 == Something "string-val"
}

test "Cache invalidate all via empty prefix" {
  let _ = setCached ("x1") "v1"
  let _ = setCached ("x2") "v2"
  let _ = invalidatePrefix ("")
  let r1 = getCached ("x1")
  let r2 = getCached ("x2")
  expect r1 == Nothing
}

test "Cache.get in case pattern" {
  let r = getCached ("pattern-key")
  expect r == Nothing
}

test "NoTtlCache compiles and operates" {
  let _ = Cache.set NoTtlCache ("ntk") "ntv"
  let r = Cache.get NoTtlCache ("ntk")
  expect r == Something "ntv"
}

test "Cache capability enforced at compile time" {
  expect True == True

}
