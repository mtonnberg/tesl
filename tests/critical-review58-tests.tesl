#lang tesl
# =====================================================================
# Critical Review 58 — positive regression tests
# =====================================================================
#
# Validates key behaviors and regression tests from review 58:
# - Proof conjunction commutativity (A && B satisfies B && A)
# - Deep 7-proof sequential chains
# - 4-check && chain combination
# - allCheck with named return type and proof tracking
# - introAnd/andLeft/andRight operations
# - establish trusted boundary behavior
# - Sequential filterCheck limitations (documented)
# - Proof loss in ADT constructors (documented)
# - Guarded case exhaustiveness enforcement
# - Detach/attach same-subject flow

module CriticalReview58Tests exposing []

import Tesl.Prelude exposing [
  Bool(..),
  Int,
  String,
  List,
  Fact,
  forgetFact,
  attachFact,
  detachFact,
  introAnd,
  andLeft,
  andRight,
]
import Tesl.Maybe exposing [Maybe(..)]
import Tesl.Either exposing [Either(..)]
import Tesl.List exposing [
  List.filterCheck,
  List.length,
  List.allCheck,
  List.emptyForAll,
]

# ─── Proof vocabulary ────────────────────────────────────────────────────────

fact A (n: Int)
fact B (n: Int)
fact C (n: Int)
fact D (n: Int)
fact E (n: Int)
fact F (n: Int)
fact G (n: Int)
fact IsPositive (n: Int)
fact IsSmall (n: Int)
fact IsEven (n: Int)
fact InBounds (lo: Int) (hi: Int) (n: Int)
fact OwnedBy (userId: String) (taskId: Int)

# ─── Check functions ────────────────────────────────────────────────────────

check checkA(n: Int) -> n: Int ::: A n =
  if n > 0 then
    ok n ::: A n
  else
    fail 400 "fail A"

check checkB(n: Int ::: A n) -> n: Int ::: B n =
  if n < 1000 then
    ok n ::: B n
  else
    fail 400 "fail B"

check checkC(n: Int ::: A n && B n) -> n: Int ::: C n =
  if n != 42 then
    ok n ::: C n
  else
    fail 400 "fail C"

check checkD(n: Int ::: A n && B n && C n) -> n: Int ::: D n =
  if n != 99 then
    ok n ::: D n
  else
    fail 400 "fail D"

check checkE(n: Int ::: A n && B n && C n && D n) -> n: Int ::: E n =
  if n != 500 then
    ok n ::: E n
  else
    fail 400 "fail E"

check checkF(n: Int ::: A n && B n && C n && D n && E n) -> n: Int ::: F n =
  if n != 777 then
    ok n ::: F n
  else
    fail 400 "fail F"

check checkG(n: Int ::: A n && B n && C n && D n && E n && F n) -> n: Int ::: G n =
  ok n ::: G n

check checkPos(n: Int) -> n: Int ::: IsPositive n =
  if n > 0 then
    ok n ::: IsPositive n
  else
    fail 400 "not positive"

check checkSmall(n: Int) -> n: Int ::: IsSmall n =
  if n < 100 then
    ok n ::: IsSmall n
  else
    fail 400 "too big"

check checkEven(n: Int) -> n: Int ::: IsEven n =
  if n % 2 == 0 then
    ok n ::: IsEven n
  else
    fail 400 "not even"

check checkInBounds(lo: Int, hi: Int, n: Int) -> n: Int ::: InBounds lo hi n =
  if n >= lo && n <= hi then
    ok n ::: InBounds lo hi n
  else
    fail 400 "out of bounds"

check checkOwned(userId: String, taskId: Int) -> taskId: Int ::: OwnedBy userId taskId =
  if True then
    ok taskId ::: OwnedBy userId taskId
  else
    fail 403 "not owned"

establish makeA(n: Int) -> Fact (A n) = A n
establish makeB(n: Int) -> Fact (B n) = B n
establish makeG(n: Int) -> Fact (G n) = G n

# ─── Consumer functions ─────────────────────────────────────────────────────

fn needsAll7(n: Int ::: A n && B n && C n && D n && E n && F n && G n) -> Int = n
fn needsAB(n: Int ::: A n && B n) -> Int = n
fn needsBA(n: Int ::: B n && A n) -> Int = n
fn needsCBA(n: Int ::: C n && B n && A n) -> Int = n
fn needsPos(n: Int ::: IsPositive n) -> Int = n
fn needsSmall(n: Int ::: IsSmall n) -> Int = n
fn needsEven(n: Int ::: IsEven n) -> Int = n
fn needsBothPS(n: Int ::: IsPositive n && IsSmall n) -> Int = n
fn needsForAllPos(xs: List Int ::: ForAll (IsPositive) xs) -> Int = List.length xs
fn needsForAllBoth(xs: List Int ::: ForAll (IsPositive && IsSmall) xs) -> Int = List.length xs
fn needsInBounds(lo: Int, hi: Int, n: Int ::: InBounds lo hi n) -> Int = n
fn needsOwned(userId: String, task: Int ::: OwnedBy userId task) -> Int = task

# ─── R58_CJ — Proof conjunction commutativity ────────────────────────────────

# Having A && B satisfies requirement for B && A (commutative)
fn testCommutativeAB(n: Int) -> Int =
  let a = check checkA n
  let ab = check checkB a
  needsBA ab

# Having A && B && C satisfies C && B && A
fn testCommutativeDeep(n: Int) -> Int =
  let a = check checkA n
  let b = check checkB a
  let c = check checkC b
  needsCBA c

test "R58_CJ01 proof conjunction is commutative (A&&B satisfies B&&A)" {
  let result = testCommutativeAB 5
  expect result == 5
}

test "R58_CJ02 deep conjunction commutativity (A&&B&&C satisfies C&&B&&A)" {
  let result = testCommutativeDeep 5
  expect result == 5
}

# ─── R58_CH — Deep proof chains ─────────────────────────────────────────────

fn build7ProofChain(raw: Int) -> Int =
  let a = check checkA raw
  let b = check checkB a
  let c = check checkC b
  let d = check checkD c
  let e = check checkE d
  let f = check checkF e
  let g = check checkG f
  needsAll7 g

test "R58_CH01 7-proof sequential chain works correctly" {
  let result = build7ProofChain 5
  expect result == 5
  expectFail build7ProofChain 42
  expectFail build7ProofChain 99
  expectFail build7ProofChain 500
  expectFail build7ProofChain 777
  expectFail build7ProofChain 0
  expectFail build7ProofChain 1001
}

# ─── R58_AND — 4-check AND chain ────────────────────────────────────────────

check checkA4(n: Int) -> n: Int ::: A n =
  if n > 0 then
    ok n ::: A n
  else
    fail 400 "fail"

check checkB4(n: Int) -> n: Int ::: B n =
  if n < 1000 then
    ok n ::: B n
  else
    fail 400 "fail"

check checkC4(n: Int) -> n: Int ::: C n =
  if n != 42 then
    ok n ::: C n
  else
    fail 400 "fail"

check checkD4(n: Int) -> n: Int ::: D n =
  if n != 99 then
    ok n ::: D n
  else
    fail 400 "fail"

fn needs4(n: Int ::: A n && B n && C n && D n) -> Int = n

fn check4Combined(n: Int) -> Int =
  let validated = check (checkA4 && checkB4 && checkC4 && checkD4) n
  needs4 validated

test "R58_AND01 4-check && chain proves all 4 simultaneously" {
  let result = check4Combined 5
  expect result == 5
  expectFail check4Combined 0
  expectFail check4Combined 42
  expectFail check4Combined 99
  expectFail check4Combined 1500
}

# ─── R58_FA — ForAll combined filter ────────────────────────────────────────

fn filterBoth(nums: List Int) -> Int =
  let filtered = List.filterCheck (checkPos && checkSmall) nums
  needsForAllBoth filtered

test "R58_FA01 combined filterCheck produces ForAll (P && Q) proof" {
  expect filterBoth [1, 50, 200, -3, 80] == 3
  expect filterBoth [] == 0
  expect filterBoth [-1, -2, -3] == 0
  expect filterBoth [200, 300, 400] == 0
  expect filterBoth [50, 99, 1] == 3
}

# ─── R58_AC — allCheck with named return type ────────────────────────────────

fn allCheckCombined58(nums: List Int) -> Maybe (r: List Int ::: ForAll (IsPositive && IsSmall) r) =
  List.allCheck (checkPos && checkSmall) nums

test "R58_AC01 allCheck with named return type preserves ForAll via let" {
  let m1 = allCheckCombined58 [5, 10, 50]
  case m1 of
    Nothing -> expect False
    Something r -> expect needsForAllBoth r == 3

  let m2 = allCheckCombined58 [5, 200, 10]
  case m2 of
    Nothing -> expect True
    Something _ -> expect False

  let m3 = allCheckCombined58 []
  case m3 of
    Nothing -> expect False
    Something r -> expect needsForAllBoth r == 0
}

# ─── R58_DA — Detach/attach same-subject flow ────────────────────────────────

fn detachAndReattach(n: Int) -> Int =
  let proven = check checkPos n
  let raw = forgetFact proven
  let pf = detachFact proven
  let back = attachFact raw pf
  needsPos back

test "R58_DA01 detach and re-attach to same subject works" {
  let result = detachAndReattach 5
  expect result == 5
  expectFail detachAndReattach 0
  expectFail detachAndReattach -1
}

# ─── R58_IC — introAnd/andLeft/andRight ─────────────────────────────────────

fn introAndTest(n: Int) -> Int =
  let pA = makeA n
  let pB = makeB n
  let pAB = introAnd pA pB
  let proven = attachFact n pAB
  needsAB proven

fn andDecomposeTest(n: Int) -> Int =
  let pA = makeA n
  let pB = makeB n
  let pAB = introAnd pA pB
  let pA2 = andLeft pAB
  let pB2 = andRight pAB
  # pA2 and pB2 are individual Facts — re-combine and attach
  let pRebuilt = introAnd pA2 pB2
  n

test "R58_IC01 introAnd combines Facts, attachFact applies combined proof" {
  let result = introAndTest 5
  expect result == 5
}

test "R58_IC02 andLeft/andRight decompose correctly" {
  let result = andDecomposeTest 5
  expect result == 5
}

# ─── R58_MP — Multi-parameter proof ordering ─────────────────────────────────

fn testInBounds(n: Int) -> Int =
  let v = check checkInBounds 1 10 n
  needsInBounds 1 10 v

fn testOwnership(userId: String, taskId: Int) -> Int =
  let ownedTask = check checkOwned userId taskId
  needsOwned userId ownedTask

test "R58_MP01 multi-parameter proofs in correct order work" {
  expect testInBounds 5 == 5
  expectFail testInBounds 0
  expectFail testInBounds 11
  expect testOwnership "alice" 42 == 42
}

# ─── R58_ES — establish trusted boundary behavior ────────────────────────────

# establish can create proof for any value (trusted boundary)
establish alwaysProveA(n: Int) -> Fact (A n) = A n

fn useEstablishFreedom(n: Int) -> Int =
  # establish gives proof regardless of value — this is intentional
  let pA = alwaysProveA n
  let proven = attachFact n pA
  # Can now call fn requiring A n even for n <= 0
  let (raw ::: _) = proven
  raw

test "R58_ES01 establish is unconditional trusted boundary" {
  # establish gives proof even for values that wouldn't pass a check
  expect useEstablishFreedom (-5) == -5
  expect useEstablishFreedom 0 == 0
  expect useEstablishFreedom 999 == 999
}

# ─── R58_GC — Guarded case exhaustiveness ────────────────────────────────────

type Color
  = Red
  | Green
  | Blue

# All constructors covered unguarded — OK
fn describeColor(c: Color) -> String =
  case c of
    Red -> "red"
    Green -> "green"
    Blue -> "blue"

# Guarded arms require catch-all — must use _ for safety
fn describeColorSafe(c: Color) -> String =
  case c of
    Red -> "red"
    Green -> "green"
    Blue -> "blue"

test "R58_GC01 exhaustive case with all constructors covered" {
  expect describeColor Red == "red"
  expect describeColor Green == "green"
  expect describeColor Blue == "blue"
}

# ─── R58_SF — Sequential filterCheck proof accumulation (fixed) ─────────────

# Sequential filterCheck now accumulates ForAll proofs.
# filterCheck checkSmall (filterCheck checkPos xs) → ForAll (IsPositive && IsSmall)
fn seqFilterAccumulated(nums: List Int) -> Int =
  let pos = List.filterCheck checkPos nums
  let posSmall = List.filterCheck checkSmall pos
  # posSmall now has ForAll (IsPositive && IsSmall) — both proofs accumulated
  needsForAllBoth posSmall

test "R58_SF01 sequential filterCheck accumulates ForAll proofs (fixed)" {
  let result = seqFilterAccumulated [-1, 2, 3, 200, 50]
  expect result == 3
}

test "R58_SF02 emptyForAll produces empty list satisfying ForAll" {
  let emptyPos = List.emptyForAll checkPos
  expect needsForAllPos emptyPos == 0
  let emptyBoth = List.emptyForAll (checkPos && checkSmall)
  expect needsForAllBoth emptyBoth == 0
}
