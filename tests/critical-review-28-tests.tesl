#lang tesl
# ─────────────────────────────────────────────────────────────────────────────
# critical-review-28-tests.tesl
#
# Adversarial test suite produced during critical review 28.
# Targets: proof soundness, type system, runtime/compile split,
# higher-order limits, stdlib edge cases, and ergonomic rough spots.
# ─────────────────────────────────────────────────────────────────────────────
module CriticalReview28Tests exposing [
  # Proof soundness IsRange28,
  checkRange28,
  requiresRange28,
  proofRoundTrip,
  # Sequential proof accumulation IsNonEmpty28,
  IsShort28,
  checkNonEmpty28,
  checkShort28,
  requiresNonEmpty28,
  combinedCheck28,
  # Newtype nominal safety UserId28(..),
  ProjectId28(..),
  makeUser28,
  makeProject28,
  requiresUser28,
  requiresProject28,
  # Bool representation boolToString28,
  # forgetFact strips proof IsValidEmail28,
  checkEmail28,
  proofForgotten28,
  # ForAll with fn-wrapper pattern IsEven28,
  checkEven28,
  doubleEven28,
  doubleAllEven28,
  # String interpolation edge cases interpolateInt28,
  interpolateNeg28,
  # Recursive ADT BinTree28(..),
  treeSum28,
  treeHeight28,
  # Partial application add28,
  multiply28,
  doubleAll28,
  # Multi-param proof cross-subject Bounded28,
  checkBounded28,
  requiresBounded28,
  wrapBounded28,
  # Case fall-through and exhaustiveness Weekday28(..),
  classifyDay28,
  Category28(..),
  describeCategory28,
  # Establish IsSmall28,
  proveSmall28,
  applySmall28,
  # Sort and filter filteredSubset28,
  # Conjunction proof IsTrimmed28,
  IsLong28,
  checkTrimmed28,
  checkLong28,
  validateTrimmedLong28,
  # Maybe handling headOrDefault28,
  safeHead28,
  nestedMaybeCheck28,
  # Proof-total divide safeDivide28,
  # Integer arithmetic negArithmetic28,
  maxSafeInt28,
  # Tuple operations swapPair28,
  # Proof detach/reattach roundTripProof28,
  # List allCheck allCheckResult28,
  # Float operations safeFloatDiv28,
  # Either operations doubleRight28,
  divOrError28,
  # Fix 5.1: List Int property test helpers listLengthNonNeg28,
  listSumReverseSame28,
]

