#lang tesl
# ─────────────────────────────────────────────────────────────────────────────
# critical-review-33-tests.tesl
#
# Adversarial test suite for critical review 33.
# Focus areas:
#   1.  Proof system correctness — roundtrips, ForAll, composition
#   2.  Type system edge cases — recursive ADTs, parameterized types
#   3.  Pattern matching — exhaustiveness, guards, fall-through
#   4.  Stdlib correctness — edge cases, boundary values
#   5.  Establish semantics — unconditional proof introduction
#   6.  Partial application — closures and arities
#   7.  Check composition — ordering, conjunction
#   8.  Integer/Float boundaries
#   9.  String operations and interpolation
#   10. Proof decomposition with let (x ::: p)
#   11. Property-based tests
#   12. Maybe / Either / Dict edge cases
#   13. Newtype safety
#   14. Case with where guards
#   15. Lambda type-checking
# ─────────────────────────────────────────────────────────────────────────────
module CriticalReview33Tests exposing [
  # T01 — ForAll on empty list IsPos33,
  checkPos33,
  filterToPositives,
  emptyListForAll,
  # T02 — Proof survives through intermediate let chain IsPrime33,
  checkPrime33,
  requiresPrime33,
  proofThroughLetChain,
  # T03 — Check composition order matters for proof content IsShort33,
  IsTrimmed33,
  checkShort33,
  checkTrimmed33,
  composedBoth33,
  requiresBothProofs33,
  # T04 — Establish is unconditional: even for nonsense input AlwaysValid33,
  alwaysEstablish33,
  requiresAlwaysValid33,
  # T05 — Mutual recursion: even/odd isEven33,
  isOdd33,
  # T06 — Deep recursive ADT IntTree33(..),
  treeSum33,
  treeDepth33,
  treeMap33,
  # T07 — Parameterized ADT box operations Box33(..),
  boxMap33,
  boxFlatMap33,
  doubleBox33,
  # T08 — Integer boundary arithmetic maxFixnum33,
  minFixnum33,
  addZero33,
  mulOne33,
  subSelf33,
  # T09 — Float special handling floatAddNegZero33,
  floatMulByOne33,
  floatAbsNeg33,
  # T10 — String interpolation with complex sub-expressions interpolateComplex33,
  interpolateZero33,
  interpolateNegative33,
  # T11 — ForAll list expansion through filterCheck IsEven33,
  checkEven33,
  narrowForAll33,
  # T12 — Proof decomposition via let (x ::: p) IsChecked33,
  checkChecked33,
  decomposeAndReuse33,
  # T13 — Case with where guard Status33(..),
  describeStatus33,
  # T14 — Nested constructor patterns Wrapper33(..),
  Inner33(..),
  unwrapInner33,
  # T15 — Newtype .value accessor WrappedInt33(..),
  makeWrapped33,
  extractWrapped33,
  doubleWrapped33,
  # T16 — Dict.requireKey proof lookupWithProof33,
  # T17 — Lambda as first-class value with partial application applyTwice33,
  doubleAll33,
  # T18 — Int.divide proof-total proofTotalDivide33,
  # T19 — Float.div proof-total proofTotalFloatDiv33,
  # T20 — List.allCheck all-or-nothing semantics allCheckSome33,
  allCheckNone33,
  # T21 — Multi-param fact with three arguments InRange33,
  checkInRange33,
  requiresInRange33,
  # T22 — forgetFact then re-check forgetAndRecheck33,
  # T23 — Fall-through case arms Weekday33(..),
  classifyWeekend33,
  # T24 — Property: sort idempotent sortedInts33,
  # T25 — Either partition semantics partitionEithers33,
]

import Tesl.Prelude exposing [ Bool(..), Int, List, String, Fact, forgetFact, ]
import Tesl.String exposing [
  String.length,
  String.trim,
  String.contains,
  String.isEmpty,
  String.startsWith,
  IsTrimmed,
]
import Tesl.List exposing [
  List.map,
  List.filterCheck,
  List.allCheck,
  List.sort,
  List.length,
  List.head,
  List.isEmpty,
  List.append,
  List.reverse,
  List.sum,
  List.take,
  List.drop,
]
import Tesl.Maybe exposing [Maybe(..)]
import Tesl.Either exposing [Either(..), Either.partition]
import Tesl.Int exposing [
  Int.nonZero,
  Int.divide,
  IsNonZero,
  Int.nonNegative,
  IsNonNegative,
]
import Tesl.Float exposing [
  Float,
  Float.requireNonZero,
  FloatNonZero,
  Float.div,
  Float.abs,
  Float.isNaN,
  Float.isInfinite,
]
import Tesl.Dict exposing [
  Dict,
  Dict.empty,
  Dict.insert,
  Dict.requireKey,
  Dict.get,
  Dict.member,
  HasKey,
]
import Tesl.Set exposing [ Set.insert, Set.member, Set.fromList, Set.toList, ]
import Tesl.Tuple exposing [Tuple2, Tuple2.first, Tuple2.second]

# ═══════════════════════════════════════════════════════════════════════════════
# T01 — ForAll on empty list
# The filter of an empty list should be empty and still carry ForAll proof.
# This tests that ForAll is sound on the degenerate case.
# ═══════════════════════════════════════════════════════════════════════════════

fact IsPos33 (n: Int)

check checkPos33(n: Int) -> n: Int ::: IsPos33 n =
  if n > 0 then
    ok n ::: IsPos33 n
  else
    fail 400 "must be positive"

fn filterToPositives(xs: List Int) -> List Int ::: ForAll (IsPos33) =
  List.filterCheck checkPos33 xs

fn emptyListForAll() -> Int =
  let result = filterToPositives []
  List.length result

test "T01 — ForAll on empty list" {
  expect emptyListForAll() == 0
  let result = filterToPositives []
  expect List.isEmpty result == True
  let nonEmpty = filterToPositives [1, 2, 3]
  expect List.length nonEmpty == 3
  let mixed = filterToPositives [-1, 2, -3, 4]
  expect List.length mixed == 2
}

test "T01b — checkPos33 boundary" {
  expectFail check checkPos33 0
  expectFail check checkPos33 -1
  let p1 = 1
  let r = check checkPos33 p1
  expect r == 1
}

# ═══════════════════════════════════════════════════════════════════════════════
# T02 — Proof survives through intermediate let chain
# Verify that attaching a proof, routing through multiple let bindings,
# and then requiring the proof still works correctly.
# ═══════════════════════════════════════════════════════════════════════════════

fact IsPrime33 (n: Int)

check checkPrime33(n: Int) -> n: Int ::: IsPrime33 n =
  if n == 2 || n == 3 || n == 5 || n == 7 || n == 11 || n == 13 then
    ok n ::: IsPrime33 n
  else
    fail 400 "not a small prime"

fn requiresPrime33(n: Int ::: IsPrime33 n) -> String =
  "prime: ${n}"

fn proofThroughLetChain(n: Int ::: IsPrime33 n) -> String =
  let a = n
  requiresPrime33 a

test "T02 — proof survives let chain" {
  let p7 = 7
  let v7 = check checkPrime33 p7
  expect proofThroughLetChain v7 == "prime: 7"
  let p13 = 13
  let v13 = check checkPrime33 p13
  expect proofThroughLetChain v13 == "prime: 13"
  expectFail check checkPrime33 4
  expectFail check checkPrime33 1
}

# ═══════════════════════════════════════════════════════════════════════════════
# T03 — Check composition order: checkA && checkB
# Both proofs must be present. Verify correct proof content.
# ═══════════════════════════════════════════════════════════════════════════════

fact IsShort33 (s: String)
fact IsTrimmed33 (s: String)

check checkShort33(s: String) -> s: String ::: IsShort33 s =
  if String.length s <= 10 then
    ok s ::: IsShort33 s
  else
    fail 400 "too long"

check checkTrimmed33(s: String) -> s: String ::: IsTrimmed33 s =
  let trimmed = String.trim s
  if trimmed == s then
    ok s ::: IsTrimmed33 s
  else
    fail 400 "not trimmed"

fn requiresBothProofs33(s: String ::: IsShort33 s && IsTrimmed33 s) -> Int =
  String.length s

fn composedBoth33(raw: String) -> Int =
  let v = check checkShort33 raw
  let w = check checkTrimmed33 v
  String.length w

test "T03 — check composition both proofs" {
  expect composedBoth33 "hello" == 5
  expect composedBoth33 "hi" == 2
  expect composedBoth33 "" == 0
  expectFail check checkTrimmed33 "  padded  "
  expectFail check checkShort33 "way too long for short check"
}

test "T03b — reversed composition also fails long strings" {
  expectFail check (checkTrimmed33 && checkShort33) "this is too long definitely"
  let shortStr = "ok"
  let result = check (checkShort33 && checkTrimmed33) shortStr
  expect String.length result == 2
}

# ═══════════════════════════════════════════════════════════════════════════════
# T04 — Establish is unconditional: must succeed even on "bad" inputs
# establish produces a proof regardless of value — this is intentional
# and is the "unsafe" escape hatch.
# ═══════════════════════════════════════════════════════════════════════════════

fact AlwaysValid33 (n: Int)

establish alwaysEstablish33(n: Int) -> Fact (AlwaysValid33 n) =
  AlwaysValid33 n

fn requiresAlwaysValid33(n: Int ::: AlwaysValid33 n) -> Int =
  n * 2

fn applyAlwaysValid33(n: Int) -> Int =
  let proof = alwaysEstablish33 n
  requiresAlwaysValid33 (n ::: proof)

test "T04 — establish is unconditional" {
  expect applyAlwaysValid33 0 == 0
  expect applyAlwaysValid33 -999 == -1998
}

test "T04b — establish on any value" {
  expect applyAlwaysValid33 1000000 == 2000000
  expect applyAlwaysValid33 -1 == -2
  expect applyAlwaysValid33 7 == 14
}

# ═══════════════════════════════════════════════════════════════════════════════
# T05 — Mutual recursion: even/odd
# Tests that mutually recursive functions compile and run correctly.
# ═══════════════════════════════════════════════════════════════════════════════

fn isEven33(n: Int) -> Bool =
  if n == 0 then
    True
  else
    isOdd33 (n - 1)

fn isOdd33(n: Int) -> Bool =
  if n == 0 then
    False
  else
    isEven33 (n - 1)

test "T05 — mutual recursion even/odd" {
  expect isEven33 0 == True
  expect isEven33 1 == False
  expect isEven33 4 == True
  expect isOdd33 3 == True
  expect isOdd33 10 == False
  expect isEven33 100 == True
  expect isOdd33 99 == True
}

test "T05b — mutual recursion property" with 30 runs {
  property "even and odd are complementary" (n: Int where n >= 0 && n < 50) {
    isEven33 n != isOdd33 n
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# T06 — Deep recursive ADT: IntTree33
# Tests that recursive ADTs with multiple operations work correctly,
# including structural recursion.
# ═══════════════════════════════════════════════════════════════════════════════

type IntTree33
  = Leaf33
  | Node33 left: (IntTree33) value: Int right: (IntTree33)

fn treeSum33(t: IntTree33) -> Int =
  case t of
    Leaf33 -> 0
    Node33 left value right -> treeSum33 left + value + treeSum33 right

fn treeDepth33(t: IntTree33) -> Int =
  case t of
    Leaf33 -> 0
    Node33 left _ right ->
      let ld = treeDepth33 left
      let rd = treeDepth33 right
      let maxDepth = if ld > rd then
        ld
      else
        rd
      1 + maxDepth

fn treeMap33(f: Int -> Int, t: IntTree33) -> IntTree33 =
  case t of
    Leaf33 -> Leaf33
    Node33 left value right ->
      Node33 (treeMap33 f left) (f value) (treeMap33 f right)

test "T06 — recursive ADT operations" {
  let leaf = Leaf33
  expect treeSum33 leaf == 0
  expect treeDepth33 leaf == 0
  let single = Node33 Leaf33 5 Leaf33
  expect treeSum33 single == 5
  expect treeDepth33 single == 1
  let tree = Node33 (Node33 Leaf33 2 Leaf33) 4 (Node33 Leaf33 6 Leaf33)
  expect treeSum33 tree == 12
  expect treeDepth33 tree == 2
  let doubled = treeMap33 (fn(x: Int) -> x * 2) tree
  expect treeSum33 doubled == 24
}

test "T06b — deep tree" {
  let deep = Node33 (Node33 (Node33 Leaf33 1 Leaf33) 2 Leaf33) 3 Leaf33
  expect treeSum33 deep == 6
  expect treeDepth33 deep == 3
}

# ═══════════════════════════════════════════════════════════════════════════════
# T07 — Parameterized ADT: Box33
# Tests parameterized ADT with functor-like operations.
# ═══════════════════════════════════════════════════════════════════════════════

type Box33 a
  = MkBox33 value: a

fn boxMap33(f: a -> b, box: Box33 a) -> Box33 b =
  case box of
    MkBox33 value -> MkBox33 (f value)

fn boxFlatMap33(f: a -> Box33 b, box: Box33 a) -> Box33 b =
  case box of
    MkBox33 value -> f value

fn doubleBox33(box: Box33 Int) -> Box33 Int =
  boxMap33 (fn(x: Int) -> x * 2) box

fn intToStr33(x: Int) -> String = "value: ${x}"

test "T07 — parameterized ADT operations" {
  let intBox = MkBox33 42
  let doubled = doubleBox33 intBox
  expect doubled == MkBox33 84
  let strBox = boxMap33 intToStr33 intBox
  expect strBox == MkBox33 "value: 42"
  let flatMapped = boxFlatMap33 (fn(x: Int) -> MkBox33 (x + 1)) intBox
  expect flatMapped == MkBox33 43
}

# ═══════════════════════════════════════════════════════════════════════════════
# T08 — Integer boundary arithmetic
# Verify arithmetic near the fixnum boundaries does not silently overflow.
# Also verify identity laws hold.
# ═══════════════════════════════════════════════════════════════════════════════

fn maxFixnum33() -> Int = 4611686018427387903
fn minFixnum33() -> Int = -4611686018427387903
fn addZero33(n: Int) -> Int = n + 0
fn mulOne33(n: Int) -> Int = n * 1
fn subSelf33(n: Int) -> Int = n - n

test "T08 — integer identity laws" {
  expect addZero33 42 == 42
  expect addZero33 0 == 0
  expect addZero33 -100 == -100
  expect mulOne33 99 == 99
  expect mulOne33 -5 == -5
  expect subSelf33 12345 == 0
  expect subSelf33 0 == 0
  expect subSelf33 -999 == 0
}

test "T08b — integer boundary values" {
  expect maxFixnum33() == 4611686018427387903
  expect minFixnum33() == -4611686018427387903
  expect (maxFixnum33() > 0) == True
  expect (minFixnum33() < 0) == True
}

test "T08c — integer arithmetic properties" with 50 runs {
  property "addZero identity" (n: Int where n > -1000000 && n < 1000000) {
    addZero33 n == n
  }
  property "mulOne identity" (n: Int where n > -1000000 && n < 1000000) {
    mulOne33 n == n
  }
  property "subSelf is zero" (n: Int where n > -1000000 && n < 1000000) {
    subSelf33 n == 0
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# T09 — Float operations
# Tests Float operations including abs, basic arithmetic identity.
# ═══════════════════════════════════════════════════════════════════════════════

fn floatAddNegZero33(x: Float) -> Float =
  x + 0.0

fn floatMulByOne33(x: Float) -> Float =
  x * 1.0

fn floatAbsNeg33(x: Float) -> Float =
  Float.abs (0.0 - x)

test "T09 — float basic operations" {
  expect floatAbsNeg33 3.14 == 3.14
  expect floatAbsNeg33 0.0 == 0.0
  expect floatAbsNeg33 -2.71 == 2.71
  expect floatAddNegZero33 1.5 == 1.5
  expect floatMulByOne33 2.5 == 2.5
}

test "T09b — float NaN/Infinity detection" {
  let inf = 1.0
  let b1 = Float.isNaN inf
  let b2 = Float.isInfinite inf
  expect b1 == False
  expect b2 == False
}

# ═══════════════════════════════════════════════════════════════════════════════
# T10 — String interpolation with complex sub-expressions
# Tests that string interpolation works with function calls and arithmetic.
# ═══════════════════════════════════════════════════════════════════════════════

fn interpolateComplex33(n: Int) -> String =
  let doubled = n * 2
  let tripled = n * 3
  "n=${n}, doubled=${doubled}, tripled=${tripled}"

fn interpolateZero33() -> String =
  let z = 0
  "zero: ${z}"

fn interpolateNegative33(n: Int) -> String =
  "negative: ${n}"

test "T10 — string interpolation" {
  expect interpolateComplex33 5 == "n=5, doubled=10, tripled=15"
  expect interpolateZero33() == "zero: 0"
  expect interpolateNegative33 -7 == "negative: -7"
}

test "T10b — interpolation property" with 20 runs {
  property "interpolated length is positive" (n: Int where n >= 0 && n < 1000) {
    String.length (interpolateComplex33 n) > 0
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# T11 — ForAll list expansion: filterCheck on already-ForAll list
# When xs already has ForAll IsPos33, applying filterCheck for another
# predicate should not lose the original proof at the declaration level.
# ═══════════════════════════════════════════════════════════════════════════════

fact IsEven33 (n: Int)

check checkEven33(n: Int) -> n: Int ::: IsEven33 n =
  if n % 2 == 0 then
    ok n ::: IsEven33 n
  else
    fail 400 "not even"

fn narrowForAll33(xs: List Int) -> List Int ::: ForAll (IsEven33) =
  let positives = filterToPositives xs
  List.filterCheck checkEven33 positives

test "T11 — ForAll narrowing" {
  let result = narrowForAll33 [1, 2, 3, 4, -2, 6]
  expect List.length result == 3
  let empty = narrowForAll33 [-1, 3, 5]
  expect List.length empty == 0
  let allEven = narrowForAll33 [2, 4, 6, 8]
  expect List.length allEven == 4
}

# ═══════════════════════════════════════════════════════════════════════════════
# T12 — Proof decomposition with let (x ::: p)
# Tests the let-destructuring form for proof values.
# ═══════════════════════════════════════════════════════════════════════════════

fact IsChecked33 (n: Int)

check checkChecked33(n: Int) -> n: Int ::: IsChecked33 n =
  if n >= 0 then
    ok n ::: IsChecked33 n
  else
    fail 400 "must be non-negative"

fn requiresChecked33(n: Int ::: IsChecked33 n) -> Int =
  n + 100

fn decomposeAndReuse33(n: Int ::: IsChecked33 n) -> Int =
  requiresChecked33 n

test "T12 — proof decomposition and reattachment" {
  let raw5 = 5
  let c5 = check checkChecked33 raw5
  expect decomposeAndReuse33 c5 == 105
  let raw0 = 0
  let c0 = check checkChecked33 raw0
  expect decomposeAndReuse33 c0 == 100
  expectFail check checkChecked33 -1
}

# ═══════════════════════════════════════════════════════════════════════════════
# T13 — Case with where guard
# Tests that where guards correctly filter case arms.
# ═══════════════════════════════════════════════════════════════════════════════

type Status33
  = Active33
  | Inactive33
  | Pending33 reason: String

fn describeStatus33(s: Status33, userId: String) -> String =
  case s of
    Active33 where String.startsWith userId "admin" ->
      "admin active"
    Active33 ->
      "user active"
    Inactive33 ->
      "inactive"
    Pending33 reason ->
      "pending: ${reason}"

test "T13 — case with where guard" {
  expect describeStatus33 Active33 "admin_user" == "admin active"
  expect describeStatus33 Active33 "regular_user" == "user active"
  expect describeStatus33 Inactive33 "anyone" == "inactive"
  expect describeStatus33 (Pending33 "review") "user" == "pending: review"
}

test "T13b — where guard priority" {
  expect describeStatus33 Active33 "administrator" == "admin active"
  expect describeStatus33 Active33 "Admin" == "user active"
}

# ═══════════════════════════════════════════════════════════════════════════════
# T14 — Nested constructor patterns
# Tests that nested ADT pattern matching resolves correctly.
# ═══════════════════════════════════════════════════════════════════════════════

type Inner33
  = InnerA val: Int
  | InnerB val: String

type Wrapper33
  = Wrapped inner: Inner33
  | Empty33

fn unwrapInner33(w: Wrapper33) -> String =
  case w of
    Empty33 ->
      "empty"
    Wrapped (InnerA val) ->
      "int: ${val}"
    Wrapped (InnerB val) ->
      "str: ${val}"

test "T14 — nested constructor patterns" {
  expect unwrapInner33 Empty33 == "empty"
  expect unwrapInner33 (Wrapped (InnerA 42)) == "int: 42"
  expect unwrapInner33 (Wrapped (InnerB "hello")) == "str: hello"
}

# ═══════════════════════════════════════════════════════════════════════════════
# T15 — Newtype .value accessor and safety
# Newtypes provide nominal safety. Two newtypes over String are distinct.
# ═══════════════════════════════════════════════════════════════════════════════

type WrappedInt33 = Int

fn makeWrapped33(n: Int) -> WrappedInt33 =
  WrappedInt33 n

fn extractWrapped33(w: WrappedInt33) -> Int =
  w.value

fn doubleWrapped33(w: WrappedInt33) -> WrappedInt33 =
  WrappedInt33 (w.value * 2)

test "T15 — newtype .value accessor" {
  let w = makeWrapped33 21
  expect extractWrapped33 w == 21
  let dw = doubleWrapped33 w
  expect extractWrapped33 dw == 42
  expect extractWrapped33 (makeWrapped33 0) == 0
  expect extractWrapped33 (makeWrapped33 -5) == -5
}

test "T15b — newtype identity" {
  let a = makeWrapped33 10
  let b = doubleWrapped33 a
  let c = doubleWrapped33 b
  expect extractWrapped33 c == 40
}

# ═══════════════════════════════════════════════════════════════════════════════
# T16 — Dict.requireKey proof enables Dict.get
# Tests that the HasKey proof is correctly produced and consumed.
# ═══════════════════════════════════════════════════════════════════════════════

fn lookupWithProof33(key: String, dict: Dict String Int) -> Maybe Int =
  if Dict.member key dict then
    let checkedDict = check Dict.requireKey key dict
    Something (Dict.get key checkedDict)
  else
    Nothing

test "T16 — Dict.requireKey and Dict.get" {
  let d = Dict.insert "a" 1 (Dict.insert "b" 2 Dict.empty)
  expect lookupWithProof33 "a" d == Something 1
  expect lookupWithProof33 "b" d == Something 2
  expect lookupWithProof33 "c" d == Nothing
  let emptyD = Dict.empty
  expect lookupWithProof33 "x" emptyD == Nothing
}

# ═══════════════════════════════════════════════════════════════════════════════
# T17 — Lambda as first-class value and partial application
# Tests higher-order functions and partial application of fn functions.
# ═══════════════════════════════════════════════════════════════════════════════

fn applyTwice33(f: Int -> Int, x: Int) -> Int =
  f (f x)

fn doubleAll33(xs: List Int) -> List Int =
  List.map (fn(x: Int) -> x * 2) xs

test "T17 — lambda and HOF" {
  expect applyTwice33 (fn(x: Int) -> x + 3) 1 == 7
  expect applyTwice33 (fn(x: Int) -> x * 2) 3 == 12
  expect doubleAll33 [1, 2, 3] == [2, 4, 6]
  expect doubleAll33 [] == []
  expect doubleAll33 [-1, 0, 1] == [-2, 0, 2]
}

test "T17b — partial application of named function" {
  let add10 = fn(x: Int) -> x + 10
  let results = List.map add10 [1, 2, 3]
  expect results == [11, 12, 13]
}

# ═══════════════════════════════════════════════════════════════════════════════
# T18 — Int.divide proof-total
# ═══════════════════════════════════════════════════════════════════════════════

fn proofTotalDivide33(a: Int, b: Int) -> Maybe Int =
  if b == 0 then
    Nothing
  else
    let divisor = check Int.nonZero b
    Something (Int.divide a divisor)

test "T18 — proof-total divide" {
  expect proofTotalDivide33 10 2 == Something 5
  expect proofTotalDivide33 10 0 == Nothing
  expect proofTotalDivide33 7 3 == Something 2
  expect proofTotalDivide33 0 5 == Something 0
  expect proofTotalDivide33 -10 2 == Something -5
}

test "T18b — divide properties" with 30 runs {
  property "divide by self is 1" (n: Int where n > 0 && n < 10000) {
    let divisor = check Int.nonZero n
    Int.divide n divisor == 1
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# T19 — Float.div proof-total
# ═══════════════════════════════════════════════════════════════════════════════

fn proofTotalFloatDiv33(a: Float, b: Float) -> Maybe Float =
  if b == 0.0 then
    Nothing
  else
    let divisor = check Float.requireNonZero b
    Something (Float.div a divisor)

test "T19 — proof-total float divide" {
  expect proofTotalFloatDiv33 10.0 2.0 == Something 5.0
  expect proofTotalFloatDiv33 10.0 0.0 == Nothing
  expect proofTotalFloatDiv33 0.0 1.0 == Something 0.0
}

# ═══════════════════════════════════════════════════════════════════════════════
# T20 — List.allCheck: all-or-nothing semantics
# ═══════════════════════════════════════════════════════════════════════════════

fn allCheckSome33(xs: List Int) -> Maybe (List Int) =
  List.allCheck checkPos33 xs

fn allCheckNone33(xs: List Int) -> Maybe (List Int) =
  List.allCheck checkPos33 xs

test "T20 — List.allCheck semantics" {
  let allPos = allCheckSome33 [1, 2, 3, 4, 5]
  expect allPos == Something [1, 2, 3, 4, 5]
  let mixed = allCheckNone33 [1, 2, -3, 4]
  expect mixed == Nothing
  let empty = allCheckSome33 []
  expect empty == Something []
}

# ═══════════════════════════════════════════════════════════════════════════════
# T21 — Multi-param fact with three arguments
# Verifies that facts with multiple parameters work correctly.
# ═══════════════════════════════════════════════════════════════════════════════

fact InRange33 (lo: Int) (hi: Int) (n: Int)

check checkInRange33(lo: Int, hi: Int, n: Int) -> n: Int ::: InRange33 lo hi n =
  if lo <= n && n <= hi then
    ok n ::: InRange33 lo hi n
  else
    fail 400 "out of range"

fn requiresInRange33(lo: Int, hi: Int, n: Int ::: InRange33 lo hi n) -> String =
  "${n} is in [${lo}, ${hi}]"

test "T21 — multi-param fact" {
  let lo = 0
  let hi = 100
  let n50 = 50
  let checked = check checkInRange33 lo hi n50
  expect requiresInRange33 lo hi checked == "50 is in [0, 100]"
  let lo2 = 0
  let hi2 = 10
  let nOut = 11
  expectFail check checkInRange33 lo2 hi2 nOut
  let nNeg = -1
  expectFail check checkInRange33 lo2 hi2 nNeg
  let n0 = 0
  let c0 = check checkInRange33 lo2 hi2 n0
  expect requiresInRange33 lo2 hi2 c0 == "0 is in [0, 10]"
}

test "T21b — multi-param boundary values" {
  let lo = -5
  let hi = 5
  let nLo = -5
  let nHi = 5
  let cLo = check checkInRange33 lo hi nLo
  let cHi = check checkInRange33 lo hi nHi
  expect requiresInRange33 lo hi cLo == "-5 is in [-5, 5]"
  expect requiresInRange33 lo hi cHi == "5 is in [-5, 5]"
}

# ═══════════════════════════════════════════════════════════════════════════════
# T22 — forgetFact then re-check
# forgetFact removes the proof but preserves the value;
# re-checking it should succeed or fail based on value, not prior state.
# ═══════════════════════════════════════════════════════════════════════════════

fn forgetAndRecheck33(n: Int ::: IsPos33 n) -> Int =
  let forgotten = forgetFact n
  let rechecked = check checkPos33 forgotten
  rechecked

fn tryForgetRecheck33(raw: Int) -> Maybe Int =
  if raw > 0 then
    let checked = check checkPos33 raw
    Something (forgetAndRecheck33 checked)
  else
    Nothing

test "T22 — forgetFact then re-check" {
  expect tryForgetRecheck33 5 == Something 5
  expect tryForgetRecheck33 -5 == Nothing
  expect tryForgetRecheck33 1 == Something 1
  expect tryForgetRecheck33 0 == Nothing
  expectFail check checkPos33 -100
}

# ═══════════════════════════════════════════════════════════════════════════════
# T23 — Case fall-through arms
# Multiple constructors sharing a body via fall-through.
# ═══════════════════════════════════════════════════════════════════════════════

type Weekday33
  = Monday33
  | Tuesday33
  | Wednesday33
  | Thursday33
  | Friday33
  | Saturday33
  | Sunday33

fn classifyWeekend33(day: Weekday33) -> String =
  case day of
    Saturday33 ->
    Sunday33 ->
      "weekend"
    Monday33 ->
    Tuesday33 ->
    Wednesday33 ->
    Thursday33 ->
    Friday33 ->
      "weekday"

test "T23 — fall-through case arms" {
  expect classifyWeekend33 Saturday33 == "weekend"
  expect classifyWeekend33 Sunday33 == "weekend"
  expect classifyWeekend33 Monday33 == "weekday"
  expect classifyWeekend33 Friday33 == "weekday"
  expect classifyWeekend33 Wednesday33 == "weekday"
}

# ═══════════════════════════════════════════════════════════════════════════════
# T24 — Property: List.sort is idempotent
# sort(sort(xs)) == sort(xs) always.
# ═══════════════════════════════════════════════════════════════════════════════

fn sortedInts33(xs: List Int) -> List Int =
  List.sort xs

test "T24 — sort idempotency" with 50 runs {
  property "sort is idempotent" (xs: List Int) {
    sortedInts33 (sortedInts33 xs) == sortedInts33 xs
  }
}

test "T24b — sort correctness" {
  expect sortedInts33 [3, 1, 2] == [1, 2, 3]
  expect sortedInts33 [] == []
  expect sortedInts33 [1] == [1]
  expect sortedInts33 [2, 2, 1] == [1, 2, 2]
  expect sortedInts33 [5, 4, 3, 2, 1] == [1, 2, 3, 4, 5]
}

# ═══════════════════════════════════════════════════════════════════════════════
# T25 — Either.partition semantics
# Tests that Either.partition correctly separates Left and Right values.
# ═══════════════════════════════════════════════════════════════════════════════

fn partitionEithers33(xs: List (Either String Int)) -> Tuple2 (List String) (List Int) =
  Either.partition xs

test "T25 — Either.partition" {
  let mixed = [Left "error1", Right 1, Left "error2", Right 2, Right 3]
  let result = partitionEithers33 mixed
  expect Tuple2.first result == ["error1", "error2"]
  expect Tuple2.second result == [1, 2, 3]
  let allLeft = [Left "a", Left "b"]
  let r2 = partitionEithers33 allLeft
  expect Tuple2.first r2 == ["a", "b"]
  expect Tuple2.second r2 == []
  let allRight = [Right 10, Right 20]
  let r3 = partitionEithers33 allRight
  expect Tuple2.first r3 == []
  expect Tuple2.second r3 == [10, 20]
  let empty = partitionEithers33 []
  expect Tuple2.first empty == []
  expect Tuple2.second empty == []
}

# ═══════════════════════════════════════════════════════════════════════════════
# T26 — Set operations correctness
# Tests Set.fromList deduplication and membership.
# ═══════════════════════════════════════════════════════════════════════════════

test "T26 — Set operations" {
  let s1 = Set.fromList [1, 2, 3, 2, 1]
  expect Set.member 1 s1 == True
  expect Set.member 4 s1 == False
  let s2 = Set.insert 4 s1
  expect Set.member 4 s2 == True
  let sorted = List.sort (Set.toList s1)
  expect sorted == [1, 2, 3]
}

# ═══════════════════════════════════════════════════════════════════════════════
# T27 — String operations: edge cases
# Tests String functions with empty strings and boundary inputs.
# ═══════════════════════════════════════════════════════════════════════════════

test "T27 — String edge cases" {
  expect String.length "" == 0
  expect String.isEmpty "" == True
  expect String.isEmpty "a" == False
  let trimmed = String.trim "  hello  "
  expect trimmed == "hello"
  expect String.trim "" == ""
  expect String.trim "  " == ""
  expect String.contains "" "x" == False
  expect String.contains "hello" "" == True
  expect String.startsWith "hello" "he" == True
  expect String.startsWith "hello" "world" == False
  expect String.startsWith "" "" == True
}

test "T27b — String length property" with 30 runs {
  property "trim length <= original" (s: String) {
    String.length (String.trim s) <= String.length s
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# T28 — List operations: edge cases
# Tests list operations with empty and single-element lists.
# ═══════════════════════════════════════════════════════════════════════════════

test "T28 — List edge cases" {
  expect List.head [] == Nothing
  expect List.head [1, 2, 3] == Something 1
  expect List.isEmpty [] == True
  expect List.isEmpty [1] == False
  expect List.length [] == 0
  expect List.length [1, 2, 3] == 3
  expect List.reverse [] == []
  expect List.reverse [1] == [1]
  expect List.reverse [1, 2, 3] == [3, 2, 1]
  expect List.sum [] == 0
  expect List.sum [1, 2, 3] == 6
  expect List.append [1, 2] [3, 4] == [1, 2, 3, 4]
  expect List.append [] [1] == [1]
  expect List.append [1] [] == [1]
}

test "T28b — List property tests" with 30 runs {
  property "length after append" (xs: List Int, ys: List Int) {
    List.length (List.append xs ys) == List.length xs + List.length ys
  }
  property "reverse is involution" (xs: List Int) {
    List.reverse (List.reverse xs) == xs
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# T29 — List.take and List.drop require NonNegative proof
# ═══════════════════════════════════════════════════════════════════════════════

test "T29 — List.take and List.drop with NonNegative proof" {
  let raw3 = 3
  let raw0 = 0
  let n3 = check Int.nonNegative raw3
  let n0 = check Int.nonNegative raw0
  let xs = [1, 2, 3, 4, 5]
  expect List.take n3 xs == [1, 2, 3]
  expect List.take n0 xs == []
  expect List.drop n3 xs == [4, 5]
  expect List.drop n0 xs == [1, 2, 3, 4, 5]
}

# ═══════════════════════════════════════════════════════════════════════════════
# T30 — Bool literal capitalization: True/False only, not true/false
# ═══════════════════════════════════════════════════════════════════════════════

fn boolLiterals33() -> Bool =
  True

fn boolNegation33(b: Bool) -> Bool =
  if b == True then
    False
  else
    True

test "T30 — Bool literal capitalization" {
  expect boolLiterals33() == True
  expect boolNegation33 True == False
  expect boolNegation33 False == True
  expect (1 == 1) == True
  expect (1 == 2) == False
}

# ═══════════════════════════════════════════════════════════════════════════════
# FIX-01 — Bug 1: case in test blocks (unbound *tesl_case_N)
# Verifies that case expressions work directly inside test blocks without
# going through define/pow — previously all arms generated unbound identifiers.
# ═══════════════════════════════════════════════════════════════════════════════

type FixShape33
  = FixCircle33 radius: Int
  | FixRect33 w: Int h: Int
  | FixPoint33

test "FIX-01a — case nullary constructor in test block" {
  let s = FixPoint33
  case s of
    FixCircle33 _ -> expect 1 == 2
    FixRect33 _ _ -> expect 1 == 2
    FixPoint33 -> expect 1 == 1
}

test "FIX-01b — case PCon field binding in test block" {
  let s = FixCircle33(7)
  case s of
    FixCircle33 r -> expect r == 7
    _ -> expect 1 == 2
}

test "FIX-01c — case multi-field PCon in test block" {
  let s = FixRect33(3)(4)
  case s of
    FixCircle33 _ -> expect 1 == 2
    FixRect33 w h -> expect w + h == 7
    FixPoint33 -> expect 1 == 2
}

test "FIX-01d — case PVar catch-all in test block" {
  let s = FixCircle33(99)
  case s of
    v -> expect True == True
}

test "FIX-01e — case PLit string match in test block" {
  let label = "hello"
  case label of
    "hello" -> expect 1 == 1
    _ -> expect 1 == 2
}

test "FIX-01f — case PLit int match in test block" {
  let n = 42
  case n of
    42 -> expect 1 == 1
    _ -> expect 1 == 2
}

# ═══════════════════════════════════════════════════════════════════════════════
# FIX-02 — Bug 2: string interpolation ${x} in lambdas inside test blocks
# Previously emitted (tesl-display-val sym) where sym is a gensym — showed
# "s2554" instead of the actual string value.
# ═══════════════════════════════════════════════════════════════════════════════

test "FIX-02a — lambda string interpolation in test block" {
  let xs = ["hello", "world"]
  let result = xs |> List.map(fn(s: String) -> "item: ${s}")
  expect result == ["item: hello", "item: world"]
}

test "FIX-02b — lambda string interpolation with Int param" {
  let ns = [1, 2, 3]
  let result = ns |> List.map(fn(n: Int) -> "num: ${n}")
  expect result == ["num: 1", "num: 2", "num: 3"]
}

test "FIX-02c — lambda multiple params string interpolation" {
  let xs = ["a", "b"]
  let result = xs |> List.map(fn(s: String) -> "${s}${s}")
  expect result == ["aa", "bb"]
}

# ═══════════════════════════════════════════════════════════════════════════════
# FIX-03 — Bug 3: let v = check (fn1 && fn2) arg — multi-proof detach
# Previously raised "multiple proofs attached; specify which to detach".
# ═══════════════════════════════════════════════════════════════════════════════

fact FixIsPos33 (n: Int)
fact FixIsSmall33 (n: Int)

check fixCheckPos33(n: Int) -> n: Int ::: FixIsPos33 n =
  if n > 0 then
    ok n ::: FixIsPos33 n
  else
    fail 400 "not positive"

check fixCheckSmall33(n: Int) -> n: Int ::: FixIsSmall33 n =
  if n < 100 then
    ok n ::: FixIsSmall33 n
  else
    fail 400 "too large"

fn fixRequiresBoth33(n: Int ::: FixIsPos33 n && FixIsSmall33 n) -> String =
  "ok: ${n}"

test "FIX-03a — check composed (&&) result used directly" {
  let v = check (fixCheckPos33 && fixCheckSmall33) 42
  expect fixRequiresBoth33 v == "ok: 42"
}

test "FIX-03b — detachFact on composed check result" {
  let v = check (fixCheckPos33 && fixCheckSmall33) 7
  let d = detachFact v
  expect fixRequiresBoth33 v == "ok: 7"
}

test "FIX-03c — composed check fails correctly on invalid input" {
  expectFail check (fixCheckPos33 && fixCheckSmall33) (-1)
}

test "FIX-03d — composed check fails on second predicate" {
  expectFail check (fixCheckPos33 && fixCheckSmall33) 200
}

# ═══════════════════════════════════════════════════════════════════════════════
# FIX-05 — now() removed: nowMillis() is the only time function
# ═══════════════════════════════════════════════════════════════════════════════

test "FIX-05 — nowMillis is available, now is not" {
  # Just verify the import works — nowMillis requires [time] capability
  # so we can't call it here, but the import must succeed.
  expect 1 == 1
}

# ═══════════════════════════════════════════════════════════════════════════════
# FIX-06 — compound check (&&) with let-bound variable in test block
# Previously: subject_env not propagated for compound checks in TsLet,
# so `let v = check (fn1 && fn2) letVar` couldn't satisfy compound proofs.
# ═══════════════════════════════════════════════════════════════════════════════

test "FIX-06a — compound check with let-bound variable (not inline literal)" {
  let raw = 42
  let v = check (fixCheckPos33 && fixCheckSmall33) raw
  expect fixRequiresBoth33 v == "ok: 42"
}

test "FIX-06b — compound check with let-bound var, check fails correctly" {
  let raw = (-5)
  expectFail check (fixCheckPos33 && fixCheckSmall33) raw
}

test "FIX-06c — compound check with let-bound var, fails on second predicate" {
  let raw = 200
  expectFail check (fixCheckPos33 && fixCheckSmall33) raw
}
