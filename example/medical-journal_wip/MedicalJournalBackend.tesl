# ══════════════════════════════════════════════════════════════════════════════
#  LOAD TESTS
# ══════════════════════════════════════════════════════════════════════════════

load-test "patient list throughput" for MjServer
  rate 50rps
  duration 2s
  requires [mjDbRead, mjDbWrite, time] {
  seed {
    insert Provider { id: "lt-doc", email: "lt@h.org", passwordHash: "x", displayName: "Dr. Load", role: Physician, department: "GP", createdAt: nowMillis() }
    insert Patient { id: "lt-pat-1", medicalRecordNumber: "LT-001", firstName: "Load", lastName: "Test1", dateOfBirth: "1990-01-01", bloodType: "O+", allergies: "None", status: ActivePatient, primaryProviderId: "lt-doc", createdAt: nowMillis(), updatedAt: nowMillis() }
    insert Patient { id: "lt-pat-2", medicalRecordNumber: "LT-002", firstName: "Load", lastName: "Test2", dateOfBirth: "1991-02-02", bloodType: "A+", allergies: "None", status: ActivePatient, primaryProviderId: "lt-doc", createdAt: nowMillis(), updatedAt: nowMillis() }
  }

  get "/patients" cookie "mj_provider_id=lt-doc"

  assert p99 < 500ms
  assert errorRate < 0.05
}

load-test "single patient lookup throughput" for MjServer
  rate 80rps
  duration 2s
  requires [mjDbRead, mjDbWrite, time] {
  seed {
    insert Provider { id: "lt-doc2", email: "lt2@h.org", passwordHash: "x", displayName: "Dr. Load2", role: Physician, department: "GP", createdAt: nowMillis() }
    insert Patient { id: "lt-pat-single", medicalRecordNumber: "LT-S", firstName: "Single", lastName: "Lookup", dateOfBirth: "1985-05-05", bloodType: "B+", allergies: "None", status: ActivePatient, primaryProviderId: "lt-doc2", createdAt: nowMillis(), updatedAt: nowMillis() }
  }

  get "/patients/lt-pat-single" cookie "mj_provider_id=lt-doc2"

  assert p95 < 300ms
  assert errorRate < 0.01
}

load-test "timeline query throughput" for MjServer
  rate 40rps
  duration 2s
  requires [mjDbRead, mjDbWrite, time] {
  seed {
    insert Provider { id: "lt-doc3", email: "lt3@h.org", passwordHash: "x", displayName: "Dr. Load3", role: Physician, department: "GP", createdAt: nowMillis() }
    insert DomainEvent { id: "lt-evt-1", aggregateType: "Patient", aggregateId: "lt-timeline-pat", eventType: "PatientCreated", summary: "Created", actorId: "lt-doc3", createdAt: nowMillis() }
    insert DomainEvent { id: "lt-evt-2", aggregateType: "JournalEntry", aggregateId: "lt-timeline-pat", eventType: "EntryAdded", summary: "Diagnosis", actorId: "lt-doc3", createdAt: nowMillis() }
    insert DomainEvent { id: "lt-evt-3", aggregateType: "Prescription", aggregateId: "lt-timeline-pat", eventType: "RxCreated", summary: "Medication", actorId: "lt-doc3", createdAt: nowMillis() }
  }

  get "/patients/lt-timeline-pat/timeline" cookie "mj_provider_id=lt-doc3"

  assert p95 < 400ms
  assert errorRate < 0.02
}

load-test "login throughput" for MjServer
  rate 100rps
  duration 2s
  requires [mjDbRead, mjDbWrite, time] {
  seed {
    insert Provider { id: "lt-login", email: "login@h.org", passwordHash: "hashed", displayName: "Dr. Login", role: Physician, department: "GP", createdAt: nowMillis() }
  }

  post "/auth/login" body { "email": "login@h.org", "password": "hashed" }

  assert p99 < 400ms
  assert errorRate < 0.01
}
