(define-checker
  (checkTitle [title : String])
  #:returns [title : String ::: (ValidTitle title)]
  (thsl-src! "example/kanel/KanelIssues.tesl" 100 (list (cons 'title *title)) (lambda () (if (tesl_import_String_isEmpty *title) (reject "title must not be empty" #:http-code 400) (if (> (raw-value (tesl_import_String_length *title)) 200) (reject "title must be at most 200 characters" #:http-code 400) (accept (ValidTitle title) #:value *title))))))

