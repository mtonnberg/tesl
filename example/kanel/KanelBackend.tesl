#lang tesl
module KanelBackend exposing [KanelServer]

# ─── Kanel — Main backend: database, queue, API, server, main ──────────────
#
# This wires together all domain modules.  Infrastructure (database, queue,
# captures, API, server, main) lives here; business logic lives in the
# domain modules.

