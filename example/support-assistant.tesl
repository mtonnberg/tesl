#lang tesl
module SupportAssistant exposing [SupportAgent, classifyTicket, Triage]

import Tesl.Prelude exposing [Int, String, Bool]
import Tesl.Json exposing [stringCodec, intCodec]
import Tesl.String exposing [String.concat]
import Tesl.Agent exposing [
  aiProvider,
  LlmProvider,
  mockProvider,
  mockToolProvider,
  toolUseStep,
  textStep,
  defineAgent,
  ask,
  askWith,
  askFor,
  decodeAs,
  replyText,
  replyToolCalls,
]

# ══════════════════════════════════════════════════════════════════════════════
# A WORKED EXAMPLE: a capability-bounded support assistant you can test with
# ZERO API keys, ZERO network, and ZERO cost.
#
# The headline AI feature is the DECLARATIVE `agent { ... }` block: you list the
# provider, the system prompt, and the typed Tesl functions the model may call as
# `tools`. The compiler DERIVES each tool's JSON schema from the function's
# parameter types and decodes the model's tool-call arguments into those typed
# parameters through the same codec path an HTTP body uses — there is no
# hand-written schema string and no argument-validation boilerplate. The tool's
# description is harvested from the function's doc-comment.
#
# AI behaviour is DETERMINISTICALLY TESTABLE: the agent value is the same in
# production and in tests; tests override the provider per call with a scripted
# `mockToolProvider` via `askWith`, then assert on the structured outcome — which
# tool ran, the validated arguments it received, the exact tool-call sequence, and
# bounded structured-output retries — all in plain `test "..."` blocks under
# `tesl test`. See manual/ai-testing.md for the narrative walkthrough.
# ══════════════════════════════════════════════════════════════════════════════

# A real provider performs outbound HTTP, so anything that runs inference
# (`ask` / `askReply` / `askWith` / `askFor`) requires the `aiProvider` capability.
# We name a domain capability that implies it and grant it where inference happens.
# A caller that omits it is a COMPILE error (V001) — see the note at the bottom.
capability supportBot implies aiProvider

# Look up the shipping status of an order by its id.
fn lookupOrder(orderId: String) -> String =
  String.concat (String.concat "order " orderId) " is: shipped"

# Issue a refund for an order. The model must pass confirmed: true; the guard lives
# inside the typed value, so "did the mutation actually happen?" is answerable by
# asserting on the tool result, deterministically.
fn refundOrder(orderId: String, confirmed: Bool) -> String =
  if confirmed then
    String.concat "refund issued for order " orderId
  else
    "refund refused: not confirmed"

# The capability-bounded support agent. provider/model/apiKey are the STATIC
# default (the production binding); the tools are typed Tesl functions referenced
# by name. Tests override the provider per call with a mock, so the agent value
# itself is identical in production and under test.
agent SupportAgent requires [supportBot] = Agent {
  provider: anthropic
  model: "claude-opus-4-8"
  apiKey: env "ANTHROPIC_API_KEY"
  systemPrompt: "You are a concise customer-support assistant. Never invent order ids."
  tools: [lookupOrder, refundOrder]
  maxTokens: 512
}

# ──────────────────────────────────────────────────────────────────────────────
# Structured output (one-shot typed extraction). This is NOT an agent loop — it is
# a single typed call that decodes the model's JSON into a proof-carrying value and
# RETRIES (bounded) if the decode fails, so a flaky reply can't smuggle an invalid
# value past the type boundary. It stays a plain function parameterised over the
# provider (the minimal one-shot primitive alongside the declarative agent block).
# ──────────────────────────────────────────────────────────────────────────────

record Triage {
  category: String
  priority: Int
}

codec Triage {
  toJson_forbidden
  fromJson [
    {
      category <- "category" with_codec stringCodec
      priority <- "priority" with_codec intCodec
    }
  ]
}

fn decodeTriage(j: String) -> Triage =
  decodeAs "Triage" j

fn classifyTicket(provider: LlmProvider, ticket: String) -> Triage requires [supportBot] =
  let agent = defineAgent provider "Classify the support ticket as JSON." 256
  askFor agent ticket decodeTriage 2

# ══════════════════════════════════════════════════════════════════════════════
# DEVELOPER-WRITTEN DETERMINISTIC TESTS
# Each scripts the model with a mock provider, then asserts on the exact,
# reproducible outcome. No keys, no network, no flakiness, no cost. A tool's name
# is its function name, so the model "calls" `lookupOrder` / `refundOrder`.
# ══════════════════════════════════════════════════════════════════════════════

# (1) Read-only tool: the model calls `lookupOrder`, its String argument is decoded
# from the model's JSON and passed to the typed function, the tool_result loops
# back, and the model's final text is returned. Exactly one tool round-trip.
test "lookup tool: derived-schema args reach the typed fn and the loop returns a reply" requires [supportBot] {
  let call = toolUseStep "lookupOrder" "call_1" "{\"orderId\":\"A-100\"}"
  let final = textStep "Your order A-100 has shipped."
  let mock = mockToolProvider [call, final]
  let reply = askWith SupportAgent "Where is my order A-100?" mock
  expect (replyText reply) == "Your order A-100 has shipped."
  expect (replyToolCalls reply) == 1
}

# (2) Guarded mutating tool, CONFIRMED: the action runs and the tool_result reflects
# it — how you assert a side effect happened.
test "refund tool: confirmed=true issues the refund" requires [supportBot] {
  let call = toolUseStep "refundOrder" "call_1" "{\"orderId\":\"A-200\",\"confirmed\":true}"
  let final = textStep "Done — your refund is on its way."
  let mock = mockToolProvider [call, final]
  let reply = askWith SupportAgent "Please refund order A-200, I confirm." mock
  expect (replyText reply) == "Done — your refund is on its way."
  expect (replyToolCalls reply) == 1
}

# (3) Guarded mutating tool, NOT confirmed: the args are well-typed, but the guard
# refuses the side effect. The tool still ran (one round-trip), proving the guard —
# not a crash — blocked the mutation.
test "refund tool: confirmed=false refuses the mutation but the loop continues" requires [supportBot] {
  let call = toolUseStep "refundOrder" "call_1" "{\"orderId\":\"A-300\",\"confirmed\":false}"
  let final = textStep "I can't refund without confirmation."
  let mock = mockToolProvider [call, final]
  let reply = askWith SupportAgent "Maybe refund A-300?" mock
  expect (replyText reply) == "I can't refund without confirmation."
  expect (replyToolCalls reply) == 1
}

# (4) The EXACT tool-call SEQUENCE: look up, then issue a confirmed refund — two
# tool round-trips before the final text.
test "multi-step: lookup then refund is exactly two tool round-trips" requires [supportBot] {
  let lookup = toolUseStep "lookupOrder" "call_1" "{\"orderId\":\"A-400\"}"
  let refund = toolUseStep "refundOrder" "call_2" "{\"orderId\":\"A-400\",\"confirmed\":true}"
  let final = textStep "Looked it up and refunded order A-400."
  let mock = mockToolProvider [lookup, refund, final]
  let reply = askWith SupportAgent "Refund A-400 if it already shipped." mock
  expect (replyText reply) == "Looked it up and refunded order A-400."
  expect (replyToolCalls reply) == 2
}

# (5) MALFORMED tool args are rejected at the boundary: the model omits the required
# "orderId", the derived arg-decoder raises, and the agent loop turns that into a
# tool_result is_error WITHOUT throwing. The loop continues and the model still
# produces a final reply — invalid model output can't reach the typed function body.
test "malformed tool args become an is_error tool_result, not an exception" requires [supportBot] {
  let call = toolUseStep "lookupOrder" "call_1" "{\"wrong\":\"shape\"}"
  let final = textStep "Sorry, I couldn't find that order."
  let mock = mockToolProvider [call, final]
  let reply = askWith SupportAgent "status?" mock
  expect (replyText reply) == "Sorry, I couldn't find that order."
  expect (replyToolCalls reply) == 1
}

# (6) STRUCTURED OUTPUT on the first reply: askFor decodes the model's JSON into a
# typed Triage value and we assert on the typed fields directly.
test "structured output: classifyTicket decodes a typed Triage on the first reply" requires [supportBot] {
  let mock = mockProvider ["{\"category\":\"billing\",\"priority\":2}"]
  let triage = classifyTicket mock "I was double-charged"
  expect triage.category == "billing"
  expect triage.priority == 2
}

# (7) RETRY: the model first returns junk that fails to decode, then valid JSON.
# askFor (bound 2) consumes BOTH replies and returns the recovered typed value.
test "structured output: classifyTicket retries past a bad reply then decodes" requires [supportBot] {
  let mock = mockProvider ["not json at all", "{\"category\":\"shipping\",\"priority\":1}"]
  let triage = classifyTicket mock "Where is my package?"
  expect triage.category == "shipping"
  expect triage.priority == 1
}

# (8) A plain one-shot ask (no tools) still works through the same machinery.
test "plain ask returns the scripted reply" requires [supportBot] {
  let agent = defineAgent (mockProvider ["Hi! How can I help?"]) "x" 64
  expect (ask agent "hello") == "Hi! How can I help?"
}

# ──────────────────────────────────────────────────────────────────────────────
# COMPILE-ERROR companion note (cannot live in a PASSING test, so documented here).
# A function that runs inference but does NOT declare the `aiProvider` capability
# (directly or via an implying capability such as `supportBot`) is a COMPILE error
# — V001. For example, this fn would FAIL `tesl --check`:
#
#   fn unguarded(p: String) -> String =
#     let agent = defineAgent (mockProvider ["x"]) "x" 10
#     ask agent p          # error[V001]: uses callees requiring [aiProvider]
#                          # Hint: add `requires [aiProvider]`
#
# The fix is to declare the capability, exactly as `classifyTicket` does. The type
# system makes the AI boundary impossible to cross by accident — even a mock-backed
# call is gated, because in production the same code reaches the network.
# ──────────────────────────────────────────────────────────────────────────────
