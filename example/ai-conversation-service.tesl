#lang tesl
module AiConversationService exposing [
  ChatServer,
  replyTurn,
  loadConversation,
  Consumer,
]

import Tesl.Prelude exposing [String, Unit, Bool(..)]
import Tesl.Maybe exposing [Maybe(..)]
import Tesl.Json exposing [stringCodec]
import Tesl.Env exposing [envInt]
import Tesl.Telemetry exposing [initTelemetry]
import Tesl.DB exposing [dbRead, dbWrite]
import Tesl.Dict exposing [Dict.lookup]
import Tesl.Http exposing [HttpRequest]
import Tesl.App exposing [App]
import Tesl.Queue exposing [pubsub]
import Tesl.Agent exposing [
  aiProvider,
  Agent,
  Conversation,
  mockProvider,
  defineAgent,
  newConversation,
  conversationFrom,
  conversationJson,
  conversationLength,
  converse,
  turnReply,
  turnConversation,
  replyText,
]

# ══════════════════════════════════════════════════════════════════════════════
# A multi-turn AI conversation service that is STATELESS across backend instances
# and ISOLATED per consumer.
#
# Flow: an API consumer POSTs a message (with a conversation id) → the backend
# loads that consumer's conversation, sends the turn to the agent, persists the
# advanced transcript, streams the reply over SSE, and returns it. The consumer
# then continues the SAME conversation with another POST — possibly served by a
# DIFFERENT backend instance, because the transcript lives in PostgreSQL, not in
# any instance's memory.
#
# Isolation is by CONSTRUCTION: every load/save query is scoped to the caller's
# id (`where ... && ownerId == requestUser.id`), so one consumer's threads are
# invisible to another — a consumer asking under someone else's conversation id
# gets a fresh conversation, never the other's transcript.
#
# Tested deterministically below with a mock provider + in-memory DB (no key, no
# network). Run live (real Claude, real cross-instance) with ANTHROPIC_API_KEY set
# and a PostgreSQL connection — see HOW TO RUN at the bottom.
# ══════════════════════════════════════════════════════════════════════════════

capability convAi implies aiProvider
capability convRead implies dbRead
capability convWrite implies dbWrite
capability convPubSub implies pubsub
capability httpAuth
capability convService implies convAi, convRead, convWrite, convPubSub, httpAuth

# A consumer is identified by an opaque id carried on the request (here, a cookie;
# swap in a bearer-token auther for programmatic clients).
record Consumer {
  id: String
}

fact Authenticated (req: Consumer)

auth consumerAuth(request: HttpRequest) -> requestUser: Consumer ::: Authenticated requestUser
  requires [httpAuth] =
  case Dict.lookup "consumerId" request.cookies of
    Something cid -> ok (Consumer { id: cid }) ::: Authenticated requestUser
    Nothing -> fail 401 "Missing consumer identity"

# One row per conversation. The transcript is the agent's conversation JSON
# (conversationJson / conversationFrom); ownerId scopes every access.
entity ConversationRecord table "ai_conversations" primaryKey id {
  id: String
  ownerId: String
  transcript: String
}

database ConversationDb = Database {
  schema: "ai_conversations"
  entities: [ConversationRecord]
  backend: Postgres (PostgresConfig {
    dbName: env "TESL_POSTGRES_DATABASE"
    user: env "TESL_POSTGRES_USER"
    password: env "TESL_POSTGRES_PASSWORD"
    connection: TcpConnection {
      host: env "TESL_POSTGRES_HOST"
      port: envInt "TESL_POSTGRES_PORT" 5432
    }
  })
}

# The streamed reply event.
type ChatEvent
  = Reply text: String

sseChannel ChatStream(conversationId: String) = SseChannel {
  database: ConversationDb
  payload: ChatEvent
}

# The agent. provider/model/apiKey are the live default; the deterministic tests
# pass a mock-provider agent into the parameterised helpers instead.
agent ChatAgent requires [convAi] = Agent {
  provider: anthropic
  model: "claude-opus-4-8"
  apiKey: env "ANTHROPIC_API_KEY"
  systemPrompt: "You are a helpful assistant. Keep replies short."
  tools: []
  maxTokens: 512
}

# ──────────────────────────────────────────────────────────────────────────────
# Conversation persistence — owner-scoped, so it is both cross-instance (state in
# PostgreSQL) and isolated (queries filter by the caller's id).
# ──────────────────────────────────────────────────────────────────────────────

# Load the caller's conversation by id, or start a fresh one. OWNER-SCOPED: the
# query filters on ownerId == requestUser.id, so another consumer's transcript is
# never even fetched — a foreign/unknown id yields a brand-new conversation.
fn loadConversation(agent: Agent, requestUser: Consumer, conversationId: String) -> Conversation
  requires [convRead] =
  case selectOne r from ConversationRecord where r.id == conversationId && r.ownerId == requestUser.id of
    Something r -> conversationFrom agent r.transcript
    Nothing -> newConversation agent

fn updateTranscript(requestUser: Consumer, conversationId: String, json: String) -> Unit
  requires [convWrite] =
  update rec in ConversationRecord
    where rec.id == conversationId && rec.ownerId == requestUser.id
    set rec.transcript = json

fn insertTranscript(requestUser: Consumer, conversationId: String, json: String) -> Unit
  requires [convWrite] =
  let rows = [ConversationRecord { id: conversationId, ownerId: requestUser.id, transcript: json }]
  insertMany rows in ConversationRecord

# Persist the advanced transcript, owner-scoped. Because the state lives in
# PostgreSQL, any backend instance can resume the conversation on the next turn.
fn saveConversation(requestUser: Consumer, conversationId: String, conv: Conversation) -> Unit
  requires [convRead, convWrite] =
  let json = conversationJson conv
  case selectOne r from ConversationRecord where r.id == conversationId && r.ownerId == requestUser.id of
    Something r -> updateTranscript requestUser conversationId json
    Nothing -> insertTranscript requestUser conversationId json

# One turn: load (or start) the caller's conversation, send the message, persist
# the advanced transcript, and return the reply. Parameterised over the agent, so
# the served handler passes the real ChatAgent while the tests pass a mock one.
fn replyTurn(agent: Agent, requestUser: Consumer, conversationId: String, message: String) -> String
  requires [convAi, convRead, convWrite] =
  let conv = loadConversation agent requestUser conversationId
  let turn = converse conv message
  let _ = saveConversation requestUser conversationId (turnConversation turn)
  replyText (turnReply turn)

# ──────────────────────────────────────────────────────────────────────────────
# HTTP surface
# ──────────────────────────────────────────────────────────────────────────────

record MessageRequest {
  message: String
}

codec MessageRequest {
  toJson_forbidden
  fromJson [
    {
      message <- "message" with_codec stringCodec
    }
  ]
}

fn parseConversationId(id: String) -> String =
  id

capturer conversationIdCapture: String using stringCodec via parseConversationId

# Send a message and get the reply; also stream it over the conversation's SSE
# channel. Uses the real ChatAgent. Isolation + persistence come from replyTurn.
handler sendMessage(
  requestUser: Consumer ::: Authenticated requestUser,
  conversationId: String,
  req: MessageRequest
) -> String
  requires [convService] =
  let reply = replyTurn ChatAgent requestUser conversationId req.message
  publish ChatStream(conversationId) Reply { text: reply }
  reply

api ChatApi {
  post "/chat/:conversationId"
    auth requestUser: Consumer ::: Authenticated requestUser via consumerAuth
    capture conversationId: String via conversationIdCapture
    body req: MessageRequest
    -> String

  sse "/chat/:conversationId/events"
    auth requestUser: Consumer ::: Authenticated requestUser via consumerAuth
    capture conversationId: String via conversationIdCapture
    subscribe ChatStream(conversationId)
}

server ChatServer for ChatApi {
  sendMessage = sendMessage
}

main() -> App requires [convService] =
  let _ = initTelemetry service "ai-conversation-service" endpoint "in-memory" console True
  let port = envInt "PORT" 8089
  App {
    database: ConversationDb
    api: ChatServer
    port: port
    sseChannels: [ChatStream]
  }

# ══════════════════════════════════════════════════════════════════════════════
# DETERMINISTIC TESTS — mock provider + in-memory DB (no key, no network).
# These exercise the persistence + isolation logic; the live served endpoint uses
# the real ChatAgent (see HOW TO RUN).
# ══════════════════════════════════════════════════════════════════════════════

# A consumer resumes their OWN conversation across calls. The second call reloads
# the persisted transcript — exactly what a different backend instance would do.
test "a consumer resumes their own conversation across calls (cross-instance)" requires [convService] {
  let agent = defineAgent (mockProvider ["Hi Alice.", "Sure — here is more."]) "sys" 256
  let alice = Consumer { id: "alice" }
  let r1 = replyTurn agent alice "conv-1" "hello"
  expect r1 == "Hi Alice."
  let r2 = replyTurn agent alice "conv-1" "tell me more"
  expect r2 == "Sure — here is more."
}

# A consumer canNOT see another consumer's conversation. Bob asks under Alice's
# conversation id; the owner-scoped load returns nothing, so Bob gets a FRESH
# conversation — never Alice's transcript.
test "a consumer cannot access another consumer's conversation (isolation)" requires [convService] {
  let agent = defineAgent (mockProvider ["secret for alice"]) "sys" 256
  let alice = Consumer { id: "alice" }
  let bob = Consumer { id: "bob" }
  let _ = replyTurn agent alice "shared-id" "remember my secret"
  let bobConv = loadConversation agent bob "shared-id"
  expect conversationLength bobConv == 0
}

# ──────────────────────────────────────────────────────────────────────────────
# HOW TO RUN (live, real Claude, real cross-instance):
#   export ANTHROPIC_API_KEY=sk-ant-...
#   export TESL_POSTGRES_DATABASE=... TESL_POSTGRES_USER=... TESL_POSTGRES_PASSWORD=...
#   export TESL_POSTGRES_HOST=localhost TESL_POSTGRES_PORT=5432
#   PORT=8089 tesl run example/ai-conversation-service.tesl    # instance A
#   PORT=8090 tesl run example/ai-conversation-service.tesl    # instance B (same DB)
#
#   # consumer "alice" starts a conversation on instance A:
#   curl -s localhost:8089/chat/alice-conv-1 -b 'consumerId=alice' \
#        -d '{"message":"My name is Alice. Remember it."}'
#   # alice continues the SAME conversation on instance B — it resumes from PG:
#   curl -s localhost:8090/chat/alice-conv-1 -b 'consumerId=alice' \
#        -d '{"message":"What is my name?"}'
#   # consumer "bob" cannot reach alice's conversation (owner-scoped):
#   curl -s localhost:8089/chat/alice-conv-1 -b 'consumerId=bob' \
#        -d '{"message":"What is the name?"}'   # → a fresh conversation, no leak
#
#   # stream replies over SSE (subscribe, then POST in another shell):
#   curl -N localhost:8089/chat/alice-conv-1/events -b 'consumerId=alice'
# ──────────────────────────────────────────────────────────────────────────────
