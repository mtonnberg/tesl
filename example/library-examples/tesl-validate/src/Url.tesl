#lang tesl
module Url exposing [
  ValidUrl,
  checkUrl,
]

import Tesl.Prelude exposing [String]
import Tesl.String exposing [String.contains, String.length]

# Library module — URL validation predicate.
# Accepts absolute URLs beginning with http:// or https://.

fact ValidUrl (s: String)

check checkUrl(s: String) -> s: String ::: ValidUrl s =
  if String.length s >= 7 && String.contains s "://" then
    ok s ::: ValidUrl s
  else
    fail 400 "invalid URL: must begin with http:// or https://"
